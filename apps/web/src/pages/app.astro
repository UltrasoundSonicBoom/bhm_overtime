---
// Phase 6 Task 4-5: app.astro = main SPA shell.
// 원본: root index.html
// SPA 의 6 tab-content placeholder 구조 + migration overlay + Tally / ChannelIO 위젯.
// app.js 진입점은 Astro <script> import 로 hash-bundle.
// regulation.css 는 ReferenceIsland (Task 5) 에서 사용 예정 — 현재는 placeholder 만.
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeIsland from '../components/tabs/HomeIsland.astro';
import ProfileIsland from '../components/tabs/ProfileIsland.astro';
import PayrollIsland from '../components/tabs/PayrollIsland.astro';
import OvertimeIsland from '../components/tabs/OvertimeIsland.astro';
import LeaveIsland from '../components/tabs/LeaveIsland.astro';
---
<BaseLayout
  title="SNUH 메이트 (SNUH Mate)"
  description="SNUH 메이트: 서울대학교병원, 보라매병원 등 급여 및 휴가 관리 어시스턴트"
  showFooterNav={true}
  extraCss={["/styles/regulation.css"]}
>
  <script is:inline>
    // AppLock FOUC Guard: pinEnabled 확인 후 body 즉시 숨겨서 잠금 전 콘텐츠 노출 방지.
    // NOTE: snuhmate_settings (Plan 2 산출 — bhm_settings 에서 변경)
    (function () { try { var s = JSON.parse(localStorage.getItem('snuhmate_settings') || '{}'); if (s.pinEnabled) { document.documentElement.style.visibility = 'hidden'; } } catch (e) { } })();
  </script>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q4QYNTQHQ8" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-Q4QYNTQHQ8');
  </script>

  <!-- ═══════════ 도메인 이전 안내 팝업 ═══════════ -->
  <div id="migrationOverlay" class="migration-overlay" style="display:none;">
    <div class="migration-card">
      <div class="onboarding-icon">🚀</div>
      <h2 class="onboarding-title">사이트 주소가 이전되었습니다!</h2>
      <div class="onboarding-sub" style="text-align: left; line-height: 1.6; margin-top: 16px;">
        <strong>snuhmate.com</strong>으로 주소가 변경되었습니다.<br /><br />
        브라우저 보안 정책상 기존 데이터는 자동으로 이동되지 않습니다. 아래 순서대로 데이터를 안전하게 옮겨보세요.

        <div
          style="background: rgba(0,0,0,0.02); border: 2px solid var(--border-active); border-radius: 12px; padding: 16px; margin-top: 16px; font-size: 0.95em;">
          <div style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px;">
            <div
              style="width: 24px; height: 24px; border-radius: 50%; background: #fbbf24; color: #1a1a1a; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              1</div>
            <div>아래 <strong>데이터 백업하기</strong> 버튼 눌러 저장 📦</div>
          </div>
          <div style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px;">
            <div
              style="width: 24px; height: 24px; border-radius: 50%; background: #ffffff; color: #1a1a1a; border: 2px solid #1a1a1a; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-sizing: border-box;">
              2</div>
            <div><strong>snuhmate.com</strong> 으로 이동 🔗</div>
          </div>
          <div style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px;">
            <div
              style="width: 24px; height: 24px; border-radius: 50%; background: #6366f1; color: white; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              3</div>
            <div>상단 메뉴에서 <strong>👤 개인정보</strong> 탭 클릭</div>
          </div>
          <div style="display: flex; align-items: flex-start; gap: 12px;">
            <div
              style="width: 24px; height: 24px; border-radius: 50%; background: #10b981; color: white; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              4</div>
            <div>하단의 <strong>📤 불러오기(복원)</strong> 눌러 파일 선택</div>
          </div>
        </div>

        <p
          style="font-size: 0.9em; margin-top: 14px; color: var(--text-muted); background: rgba(0,0,0,0.05); padding: 10px; border-radius: 8px;">
          ※ 처음 접속하시는 분은 '그냥 시작하기'를 누르시거나 바로 새 주소로 이동하세요.
        </p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 24px;">
        <button class="migration-btn primary" data-action="downloadBackupAndStay" style="width: 100%;">📦 데이터 백업하기 (자동 이동
          멈춤)</button>
        <a href="https://snuhmate.com" class="migration-btn secondary" style="width: 100%;">🔗 snuhmate.com으로 바로 이동</a>
        <div id="migrationCountdownText"
          style="font-size: 0.95em; color: var(--text-secondary); background: rgba(99,102,241,0.08); border-radius: 10px; padding: 12px 14px; line-height: 1.5;">
          <strong>3초 뒤</strong> snuhmate.com으로 자동 이동합니다.
        </div>
        <button data-action="closeMigrationModal"
          style="border: none; background: none; color: var(--text-muted); text-decoration: underline; cursor: pointer; font-size: 0.95em; margin-top: 8px;">그냥
          시작하기 (기존 데이터 무시)</button>
      </div>
    </div>
  </div>

  <main class="main">

    <!-- 데모 모드 배너 (모든 탭 공통) -->
    <div id="demoBanner"
      style="display:none; align-items:center; gap:10px; background:var(--amber,#F5A623); color:var(--ink,#1a1a1a); padding:10px 16px; border-radius:10px; margin-bottom:8px; font-size:14px; font-weight:600;">
      <span>🎮 데모 모드</span>
      <span style="font-weight:400; flex:1;">샘플 데이터로 체험 중이에요. 실제 데이터는 저장되지 않아요.</span>
      <button data-action="exitDemoMode"
        style="background:var(--ink,#1a1a1a); color:#fff; border:none; border-radius:6px; padding:4px 10px; font-size:13px; font-weight:600; cursor:pointer; flex-shrink:0;">나가기</button>
    </div>

    <!-- ═══════════ 🏠 홈 ═══════════ -->
    <HomeIsland />

    <!-- ═══════════ 💰 급여 섹션 ═══════════ -->
    <PayrollIsland />

    <!-- ═══════════ ⏰ 시간외·온콜 관리 ═══════════ -->
    <OvertimeIsland />

    <!-- ═══════════ 📅 휴가 관리 ═══════════ -->
    <LeaveIsland />

    <!-- ═══════════ 📋 규정·챗봇 ═══════════ -->
    <div class="tab-content" id="tab-reference"></div>

    <!-- ═══════════ 👤 개인정보 ═══════════ -->
    <ProfileIsland />

    <!-- ═══════════ ⚙️ 설정 ═══════════ -->
    <div class="tab-content" id="tab-settings"></div>

    <!-- ═══════════ 📢 피드백 방 ═══════════ -->
    <div class="tab-content" id="tab-feedback"></div>

  </main>

  <!-- Toast notification -->
  <div id="otToast" class="ot-toast" style="display:none;"></div>

  <!-- Tally 위젯 부트스트랩 -->
  <script is:inline>
    var d = document, w = "https://tally.so/widgets/embed.js", v = function () { "undefined" != typeof Tally ? Tally.loadEmbeds() : d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function (e) { e.src = e.dataset.tallySrc })) }; if ("undefined" != typeof Tally) v(); else if (d.querySelector('script[src="' + w + '"]') == null) { var s = d.createElement("script"); s.src = w, s.onload = v, s.onerror = v, d.body.appendChild(s); }
  </script>

  <!-- Service Worker (offline-first + 안전 갱신) -->
  <script is:inline>
    if('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(function(e){console.warn('[SW] register failed', e)});
  </script>

  <!-- Main app entry — Astro 가 hash-bundle 로 처리. -->
  <script>
    import '../client/app.js';
  </script>

  <style is:global>
    /* ChannelIO 채팅창 너비 제한 */
    #ch-plugin-script-iframe {
      max-width: 500px !important;
    }
  </style>
</BaseLayout>
