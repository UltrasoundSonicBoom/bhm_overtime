---
// Phase 6 Task 4-2: index.astro = onboarding (landing page).
// 원본: root onboarding.html
// SPA root 였던 / 가 onboarding 으로 통합 (4-3 에서 SPA 는 /app 로 이동).
// 인라인 script/style 은 /client/onboarding.js, /styles/onboarding.css 로 분리.
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="SNUH 메이트 - 시작하기"
  description="내 휴가, 시간외, 급여 분석. SNUH Mate 가 도와드릴게요."
  showFooterNav={false}
  extraCss={["/styles/onboarding.css"]}
>
  <!-- ════════ 1. Hero ════════ -->
  <section class="section hero">
    <div class="section-inner">
      <img src="/snuhmatecircle.png" alt="SNUH 메이트" class="hero-logo reveal">
      <h1 class="hero-title reveal d1">
        안녕하세요,<br>

      </h1>
      <p class="hero-sub reveal d2">
        내 휴가, 시간외, 급여 분석 등 , 궁금한 규정<br>
        등등 <b>SNUH Mate</b>가 도와드릴게요 :)
      </p>
    </div>
    <div class="scroll-hint">
      <div class="scroll-hint-down">
        아래로 스크롤하세요
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round">
          <path d="M12 5v14M19 12l-7 7-7-7" />
        </svg>
      </div>
      <div class="scroll-hint-end" data-action="scrollToBottom" style="cursor:pointer;">
        끝으로
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" width="16" height="16">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </section>

  <!-- ════════ 2. 시간외 ════════ -->
  <section class="section sec-violet">
    <div class="section-inner">
      <div class="pain-tag reveal">&#x1f62e; 이번 달 시간외, 내가 얼마나 했더라...</div>
      <h2 class="feat-title reveal d1">
        내 시간외 기록,<br>한눈에 모아볼 수 있어요.
      </h2>
      <p class="feat-desc reveal d2" style="color:white">
        언제, 얼마나 일했는지 기록하면<br>
        예상 수당까지 자동으로 계산돼요.<br>
        이제 엑셀 안 써도 돼요!
      </p>
      <div class="neo-card reveal d3">
        <div class="mock-row">
          <div class="mock-icon" style="background:#ede9fe;">&#x23F0;</div>
          <div>
            <div class="mock-label">4/7 (월) 시간외</div>
            <div class="mock-sub">18:00 ~ 21:00 &middot; 3시간</div>
          </div>
          <div class="mock-value" style="color:var(--violet);">+38,400</div>
        </div>
        <div class="mock-row">
          <div class="mock-icon" style="background:#fef3c7;">&#x1f314;</div>
          <div>
            <div class="mock-label">4/8 (화) 당직</div>
            <div class="mock-sub">17:30 ~ 08:30 &middot; 15시간</div>
          </div>
          <div class="mock-value" style="color:var(--violet);">+192,000</div>
        </div>
        <div class="mock-row">
          <div class="mock-icon" style="background:#fce7f3;">&#x1f4de;</div>
          <div>
            <div class="mock-label">4/9 (수) 온콜</div>
            <div class="mock-sub">호출 1회 &middot; 2시간</div>
          </div>
          <div class="mock-value" style="color:var(--violet);">+25,600</div>
        </div>
        <div class="mock-total">
          <div class="mock-total-label">4월 예상 수당</div>
          <div class="mock-total-value" style="color:var(--violet);">620,400원</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 3. 휴가 ════════ -->
  <section class="section sec-emerald">
    <div class="section-inner">
      <div class="pain-tag reveal">&#x1f914; 연차 며칠 남았지? 인사팀에 또 물어봐야 하나...</div>
      <h2 class="feat-title reveal d1">
        남은 연차,<br>여기서 바로 확인하세요.
      </h2>
      <p class="feat-desc reveal d2">
        연차, 병가, 공가, 청원휴가까지<br>
        쓸 때마다 자동으로 차감돼요.<br>
        휴가 계획 짜기 훨씬 편해져요.
      </p>
      <!-- 2026년 휴가 현황 Header -->
      <div class="lv-header-mock reveal d3" style="max-width:320px;">
        <span class="toggle-icon" style="font-size:12px; color:var(--ink);">▼</span>
        <div class="icon-box">⛱</div>
        <span style="font-size:18px; font-weight:800;">2026년 휴가 현황</span>
      </div>

      <!-- 2x2 Grid Mockup -->
      <div class="lv-stat-grid-onboarding reveal d4" style="max-width:340px;">
        <div class="lv-stat-item">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-weight:700; font-size:14px;">연차</span>
            <span style="color:var(--accent-emerald); font-weight:800; font-size:13px;">24일</span>
          </div>
          <div class="lv-progress-bar">
            <div class="lv-progress-fill" style="width:0%;"></div>
          </div>
          <div style="font-size:11px; color:var(--muted); font-weight:700;">0/24일 사용</div>
        </div>
        <div class="lv-stat-item">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-weight:700; font-size:14px;">검진휴가</span>
            <span style="color:var(--accent-emerald); font-weight:800; font-size:13px;">1일</span>
          </div>
          <div class="lv-progress-bar">
            <div class="lv-progress-fill" style="width:0%;"></div>
          </div>
          <div style="font-size:11px; color:var(--muted); font-weight:700;">0/1일 사용</div>
        </div>
        <div class="lv-stat-item">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-weight:700; font-size:14px;">교육연수</span>
            <span style="color:var(--accent-emerald); font-weight:800; font-size:13px;">3일</span>
          </div>
          <div class="lv-progress-bar">
            <div class="lv-progress-fill" style="width:0%;"></div>
          </div>
          <div style="font-size:11px; color:var(--muted); font-weight:700;">0/3일 사용</div>
        </div>
        <div class="lv-stat-item">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-weight:700; font-size:14px;">병원필수교육</span>
            <span style="color:var(--accent-emerald); font-weight:800; font-size:13px;">3일</span>
          </div>
          <div class="lv-progress-bar">
            <div class="lv-progress-fill" style="width:0%;"></div>
          </div>
          <div style="font-size:11px; color:var(--muted); font-weight:700;">0/3일 사용</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 4. 급여 ════════ -->
  <section class="section sec-blue">
    <div class="section-inner">
      <div class="pain-tag reveal">&#x1f4b8; 급여명세서, 볼 때마다 뭐가 뭔지 모르겠어...</div>
      <h2 class="feat-title reveal d1">
        내 급여,<br>이제 쉽게 이해돼요.
      </h2>
      <p class="feat-desc reveal d2">
        급여명세서 PDF를 올리면<br>
        항목별로 깔끔하게 정리해드려요.<br>
        전월 대비 변동도 한눈에!
      </p>
      <div class="neo-card reveal d3">
        <div style="font-size:13px; color:var(--muted); font-weight:600; margin-bottom:10px;">2026년 3월 급여</div>
        <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px;">
          <div style="font-size:24px; font-weight:900;">3,842,160원</div>
          <div style="font-size:13px; color:var(--emerald); font-weight:700;">+124,000 vs 2월</div>
        </div>
        <div class="color-bar" style="margin-bottom:2px;">
          <div style="flex:5.5; background:var(--blue);"></div>
          <div style="flex:2; background:var(--emerald);"></div>
          <div style="flex:1.5; background:var(--amber);"></div>
          <div style="flex:1; background:#e5e5e5;"></div>
        </div>
        <div class="legend">
          <div class="legend-item">
            <div class="legend-dot" style="background:var(--blue);"></div>기본급
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:var(--emerald);"></div>수당
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:var(--amber);"></div>시간외
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#e5e5e5;"></div>공제
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 5. 규정 ════════ -->
  <section class="section sec-rose">
    <div class="section-inner">
      <div class="pain-tag reveal">&#x1f4d6; 이거 규정에 있는 건데... 어디서 찾지?</div>
      <h2 class="feat-title reveal d1">
        단체협약 규정,<br>직접 찾아볼 수 있어요.
      </h2>
      <p class="feat-desc reveal d2">
        FAQ, 원문 검색, PDF 뷰어까지<br>
        한 곳에서 바로 확인하세요.
      </p>
      <div class="neo-card reveal d3" style="padding:20px;">
        <!-- 규정 헤더 -->
        <div style="font-size:16px; font-weight:800; margin-bottom:4px;">시간외근무</div>
        <div style="font-size:12px; color:var(--muted); font-weight:600; margin-bottom:12px;">&#x1f4cc; 제34조, 제47조</div>
        <!-- 규정 요약 -->
        <div style="font-size:13px; line-height:1.7; color:var(--ink); margin-bottom:14px;">
          주 최대 52시간 (소정 40 + 연장 12).<br>
          15분 단위 계산 (2020년~).<br>
          <span style="color:var(--muted);">&bull;</span> 연장근무: 통상임금 &times; 1/209 &times; 150%<br>
          <span style="color:var(--muted);">&bull;</span> 야간가산: 통상임금 &times; 1/209 &times; 200%<br>
          <span style="color:var(--muted);">&bull;</span> 휴일근무: 150% (8h 이내), 200% (초과)
        </div>
        <!-- 내 수당 테이블 -->
        <div style="border-top:3px solid var(--ink); padding-top:12px;">
          <div style="font-size:13px; font-weight:700; margin-bottom:8px;">&#x1f4ca; 내 시간외수당 (1시간 기준)</div>
          <div class="reg-mock-table">
            <div class="reg-mock-row">
              <span class="reg-mock-label">내 시급</span>
              <span class="reg-mock-val" style="color:var(--ink);">32,424원</span>
            </div>
            <div class="reg-mock-row">
              <span class="reg-mock-label">연장 1시간</span>
              <span class="reg-mock-val" style="color:var(--violet);">48,636원</span>
            </div>
            <div class="reg-mock-row">
              <span class="reg-mock-label">야간 1시간</span>
              <span class="reg-mock-val" style="color:var(--rose);">64,848원</span>
            </div>
            <div class="reg-mock-row">
              <span class="reg-mock-label">휴일 1시간 (8h 이내)</span>
              <span class="reg-mock-val" style="color:var(--violet);">48,636원</span>
            </div>
            <div class="reg-mock-row">
              <span class="reg-mock-label">휴일 1시간 (8h 초과)</span>
              <span class="reg-mock-val" style="color:var(--rose);">64,848원</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 6. 프라이버시 ════════ -->
  <section class="section sec-cream">
    <div class="section-inner">
      <div class="shield reveal">&#x1f512;</div>
      <h2 class="feat-title reveal d1">
        내 데이터는<br>오직 내 폰에만.
      </h2>
      <p class="feat-desc reveal d2">
        서버에 아무것도 보내지 않아요.<br>
        로그인도 필요 없어요.<br>
        기기 바꿀 땐 백업 한 번이면 끝!
      </p>
      <div class="badges reveal d3">
        <div class="badge">&#x2705; 서버 전송 없음</div>
        <div class="badge">&#x1f513; 로그인 불필요</div>
        <div class="badge">&#x1f4e6; 백업/복원</div>
      </div>
    </div>
  </section>

  <!-- ════════ 7. CTA ════════ -->
  <section class="section" style="background: var(--amber);">
    <div class="section-inner">
      <h2 class="feat-title reveal" style="font-size:clamp(26px, 7vw, 42px);">
        이제 복잡한 건<br>SNUH Mate에서 관리하세요.
      </h2>
      <p class="feat-desc reveal d1" style="color:var(--ink); opacity:0.6;">설치 없이, 웹에서 바로.</p>
      <div class="cta-group reveal d2">
        <a href="/app" class="cta-primary">시작하기 &rarr;</a>
        <a href="/app?tutorial=1" class="cta-secondary">&#x1f393; 사용법 익히기 [튜토리얼]</a>
      </div>
    </div>
    <div class="footer-text">만든 사람: 김계환 (핵의학과)</div>
  </section>

  <script src="/client/onboarding.js" is:inline></script>
</BaseLayout>

<style is:global>
  /* Phase 6 Task 4-2: onboarding 페이지에서는 BaseLayout 의 빈 sharedHeader 숨김. */
  body > #sharedHeader:empty { display: none; }
</style>
