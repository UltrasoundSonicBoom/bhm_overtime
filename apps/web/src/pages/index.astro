---
// Phase 6 Task 4-2: onboarding horizontal carousel (10 slides).
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="SNUH 메이트 - 시작하기"
  description="내 휴가, 시간외, 급여 분석. SNUH Mate가 도와드릴게요."
  showFooterNav={false}
  extraCss={["/styles/onboarding.css"]}
>
  <div class="ob-frame">
    <div class="ob-viewport">
      <div id="ob-deck">

        <!-- 1. 히어로 -->
        <section class="ob-slide ob-cream">
          <div class="ob-inner">
            <img src="/snuhmatecircle.png" alt="SNUH Mate" class="ob-logo ob-reveal">
            <div class="ob-rule ob-reveal"></div>
            <h1 class="ob-display ob-reveal">내 수당,<br>내가 먼저<br>알아야죠.</h1>
            <p class="ob-sub ob-reveal">슬기로운 병원생활 메이트</p>
            <p class="ob-lede ob-reveal">연장·야간·온콜 수당 계산, 연차 현황, 급여명세서 분석. 서울대병원 직원을 위한 계산기예요.</p>
          </div>
        </section>

        <!-- 2. 시간외 -->
        <section class="ob-slide ob-brand">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">01 · 시간외 수당</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">연장 150%,<br>야간 200%,<br>온콜은 또 달라요.</h2>
            <p class="ob-lede ob-reveal">날짜 찍으면 공휴일 자동 판별. 이브닝 22시 이후는 야간 시간 분리까지. 15분 단위 절삭도 알아서 해요.</p>
            <div class="ob-mockup ob-reveal">
              <div class="ob-m-head">
                <div class="ob-m-icon indigo">⏰</div>
                <span>4월 시간외 내역</span>
              </div>
              <div class="ob-ot-entry">
                <div class="ob-ot-head">
                  <span class="ob-ot-date">4월 28일 · 연장근무</span>
                  <span class="ob-ot-pay">93,060원</span>
                </div>
                <div class="ob-ot-line">
                  <span>1.5h × 62,040원</span>
                  <span class="ob-badge indigo">×150%</span>
                </div>
              </div>
              <div class="ob-ot-entry">
                <div class="ob-ot-head">
                  <span class="ob-ot-date">4월 25일 · 야간근무</span>
                  <span class="ob-ot-pay">62,040원</span>
                </div>
                <div class="ob-ot-line">
                  <span>1.0h × 62,040원</span>
                  <span class="ob-badge rose">×200%</span>
                </div>
              </div>
              <div class="ob-ot-entry">
                <div class="ob-ot-head">
                  <span class="ob-ot-date">4월 22일 · 휴일근무</span>
                  <span class="ob-ot-pay">186,120원</span>
                </div>
                <div class="ob-ot-line">
                  <span>3.0h × 62,040원</span>
                  <span class="ob-badge amber">×150%</span>
                </div>
              </div>
              <div class="ob-result">
                <span class="ob-result-label">4월 예상 수당</span>
                <span class="ob-result-val">620,400원</span>
              </div>
            </div>
          </div>
        </section>

        <!-- 3. 근무 (NEW) -->
        <section class="ob-slide ob-ink">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">02 · 근무</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">내 스케줄,<br>동료 스케줄,<br>한 화면에.</h2>
            <p class="ob-lede ob-reveal">엑셀 근무표 올리면 D·E·N이 달력에 자동 입력. 내 월간 달력과 부서 전체 시간표 모두 확인.</p>
            <div class="ob-sched-2up ob-reveal">
              <!-- 부서 전체 (주간) -->
              <div class="ob-mockup ob-sched-card">
                <div class="ob-stab-row">
                  <span class="ob-stab">내 스케줄</span><span class="ob-stab on">부서 전체</span>
                  <span class="ob-stab-r">주간</span>
                </div>
                <div class="ob-dept-tbl">
                  <div class="ob-dept-hd-row">
                    <div class="ob-dn-cell">간호사</div>
                    <div class="ob-dd">금<br><small>1</small></div>
                    <div class="ob-dd">토<br><small>2</small></div>
                    <div class="ob-dd sun">일<br><small>3</small></div>
                    <div class="ob-dd">월<br><small>4</small></div>
                    <div class="ob-dd red">화<br><small>5</small></div>
                  </div>
                  <div class="ob-dept-row me">
                    <div class="ob-dn-cell">김계환</div>
                    <div><span class="ob-sc d">D</span></div>
                    <div><span class="ob-sc e">E</span></div>
                    <div><span class="ob-sc n">N</span></div>
                    <div><span class="ob-sc n">N</span></div>
                    <div><span class="ob-sc off">OFF</span></div>
                  </div>
                  <div class="ob-dept-row">
                    <div class="ob-dn-cell">김지원</div>
                    <div><span class="ob-sc n">N</span></div>
                    <div><span class="ob-sc off">OFF</span></div>
                    <div><span class="ob-sc off">OFF</span></div>
                    <div><span class="ob-sc d">D</span></div>
                    <div><span class="ob-sc e">E</span></div>
                  </div>
                  <div class="ob-dept-row">
                    <div class="ob-dn-cell">박서연</div>
                    <div><span class="ob-sc d">D</span></div>
                    <div><span class="ob-sc e">E</span></div>
                    <div><span class="ob-sc d">D</span></div>
                    <div><span class="ob-sc d">D</span></div>
                    <div><span class="ob-sc n">N</span></div>
                  </div>
                </div>
              </div>
              <!-- 내 스케줄 (월간) -->
              <div class="ob-mockup ob-sched-card">
                <div class="ob-stab-row">
                  <span class="ob-stab on">내 스케줄</span><span class="ob-stab">부서 전체</span>
                  <span class="ob-stab-r">월간</span>
                </div>
                <div class="ob-mcal-hd">← 2026년 5월 →</div>
                <div class="ob-mcal">
                  <div class="ob-mc-dow sun">일</div><div class="ob-mc-dow">월</div><div class="ob-mc-dow">화</div><div class="ob-mc-dow">수</div><div class="ob-mc-dow">목</div><div class="ob-mc-dow">금</div><div class="ob-mc-dow sat">토</div>
                  <div class="ob-mc"></div><div class="ob-mc"></div><div class="ob-mc"></div><div class="ob-mc"></div><div class="ob-mc"></div>
                  <div class="ob-mc hol"><span>1</span><span class="ob-sc d">D</span></div>
                  <div class="ob-mc"><span>2</span><span class="ob-sc e">E</span></div>
                  <div class="ob-mc today"><span>3</span><span class="ob-sc n">N</span></div>
                  <div class="ob-mc"><span>4</span><span class="ob-sc n">N</span></div>
                  <div class="ob-mc hol"><span>5</span><span class="ob-sc off">OFF</span></div>
                  <div class="ob-mc"><span>6</span><span class="ob-sc off">OFF</span></div>
                  <div class="ob-mc"><span>7</span><span class="ob-sc d">D</span></div>
                  <div class="ob-mc"><span>8</span><span class="ob-sc e">E</span></div>
                  <div class="ob-mc"><span>9</span><span class="ob-sc d">D</span></div>
                  <div class="ob-mc"><span>10</span><span class="ob-sc d">D</span></div>
                  <div class="ob-mc"><span>11</span><span class="ob-sc e">E</span></div>
                  <div class="ob-mc"><span>12</span><span class="ob-sc n">N</span></div>
                  <div class="ob-mc"><span>13</span><span class="ob-sc n">N</span></div>
                  <div class="ob-mc"><span>14</span><span class="ob-sc off">OFF</span></div>
                  <div class="ob-mc"><span>15</span><span class="ob-sc al">AL</span></div>
                  <div class="ob-mc"><span>16</span><span class="ob-sc d">D</span></div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 4. 휴가 -->
        <section class="ob-slide ob-success">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">03 · 휴가</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">내 휴가,<br>내가 직접<br>캘린더에서.</h2>
            <p class="ob-lede ob-reveal">연차·교육·헌혈·경조휴가까지 한 달력에. 공휴일은 자동으로 표시돼요.</p>
            <div class="ob-mockup ob-reveal">
              <div class="ob-lv-hd">
                <span>◀</span>
                <span class="ob-lv-month">2026년 5월</span>
                <span>▶</span>
              </div>
              <div class="ob-lv-grid">
                <div class="ob-lv-dow r">일</div><div class="ob-lv-dow">월</div><div class="ob-lv-dow">화</div><div class="ob-lv-dow">수</div><div class="ob-lv-dow">목</div><div class="ob-lv-dow">금</div><div class="ob-lv-dow b">토</div>
                <div></div><div></div><div></div><div></div><div></div>
                <div class="ob-lv-cd pk"><span class="ob-lv-dn pk">1</span><div class="ob-lv-hn">근로자</div></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">2</span></div>
                <div class="ob-lv-cd td"><span class="ob-lv-dn td">3</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">4</span><div class="ob-lv-chip lv-an">연차</div></div>
                <div class="ob-lv-cd pk"><span class="ob-lv-dn pk">5</span><div class="ob-lv-hn">어린이</div></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">6</span><div class="ob-lv-chip lv-ed">보수교</div></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">7</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">8</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn b">9</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">10</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">11</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">12</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">13</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">14</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">15</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn b">16</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">17</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">18</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">19</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">20</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">21</span><div class="ob-lv-chip lv-pt">시간차</div></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">22</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn b">23</span></div>
                <div class="ob-lv-cd pk"><span class="ob-lv-dn pk">24</span><div class="ob-lv-hn">부처님</div></div>
                <div class="ob-lv-cd pk"><span class="ob-lv-dn pk">25</span><div class="ob-lv-hn">대체공</div></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">26</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">27</span><div class="ob-lv-chip lv-bl">헌혈휴</div></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">28</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">29</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn b">30</span></div>
                <div class="ob-lv-cd"><span class="ob-lv-dn">31</span></div>
                <div></div><div></div><div></div><div></div><div></div><div></div>
              </div>
              <div class="ob-lv-legend">
                <span class="ob-lv-leg-hol">● 공휴일</span>
                <span class="ob-lv-chip lv-an">법정</span>
                <span class="ob-lv-chip lv-ed">건강</span>
                <span class="ob-lv-chip lv-pt">교육</span>
              </div>
            </div>
          </div>
        </section>

        <!-- 4. 급여 -->
        <section class="ob-slide ob-info">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">04 · 급여</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">이번 달 시간외,<br>다음 달 월급에<br>얼마 더 붙을까요?</h2>
            <p class="ob-lede ob-reveal">시간외 수당 계산기, 예상 실수령액, 퇴직금 시뮬레이션까지. 명세서 PDF 올리면 항목별로 다 분해돼요.</p>
            <div class="ob-mockup ob-reveal">
              <div class="ob-m-head">
                <div class="ob-m-icon indigo">💰</div>
                <span>5월 예상 급여 <span class="ob-badge emerald" style="margin-left:4px">시뮬레이션</span></span>
              </div>
              <div class="ob-pay-row">
                <span class="ob-pay-label">기본급 + 수당</span>
                <span class="ob-pay-val">3,280,000원</span>
              </div>
              <div class="ob-pay-row">
                <span class="ob-pay-label">4월 시간외 (연장 7h + 야간 2h)</span>
                <span class="ob-pay-val up">+682,440원</span>
              </div>
              <div class="ob-pay-row">
                <span class="ob-pay-label">공제 (건보·소득세 등)</span>
                <span class="ob-pay-val down">-318,700원</span>
              </div>
              <div class="ob-result">
                <span class="ob-result-label">예상 실수령액</span>
                <span class="ob-result-val">3,643,740원</span>
              </div>
              <div class="ob-pay-row" style="margin-top:8px;border-top:1px solid #F5F0E1;padding-top:8px">
                <span class="ob-pay-label">퇴직금 (현재 기준)</span>
                <span class="ob-pay-val">18,420,000원 <span class="ob-badge amber" style="margin-left:4px">시뮬레이션</span></span>
              </div>
            </div>
          </div>
        </section>

        <!-- 5. 규정 -->
        <section class="ob-slide ob-warn">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">05 · 단체협약</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">종이 노조수첩<br>그만.</h2>
            <p class="ob-lede ob-reveal">2026 단체협약 원문을 핸드폰에서 바로 확인하세요. 휴직·휴가·근무·수당 조항 전체 검색, 즐겨찾기 저장.</p>
            <div class="ob-mockup ob-reveal">
              <div class="ob-search">🔍 <span>경조사 휴가 며칠</span></div>
              <div class="ob-reg-item">
                <span class="ob-badge rose">휴가 · 제44조</span>
                <div class="ob-reg-text">배우자 출산 — <strong>10일</strong> (유급)</div>
              </div>
              <div class="ob-reg-item">
                <span class="ob-badge amber">휴직 · 제51조</span>
                <div class="ob-reg-text">육아휴직 — 최대 <strong>2년</strong>, 첫 1년 통상임금 80%</div>
              </div>
              <div class="ob-reg-item">
                <span class="ob-badge indigo">수당 · 제34조</span>
                <div class="ob-reg-text">온콜 출근 시 교통비 <strong>50,000원</strong> + 2시간 인정</div>
              </div>
            </div>
          </div>
        </section>

        <!-- 6. AUTH (Step 1/4) -->
        <section class="ob-slide ob-cream">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">Step 1 / 4 · 시작 방식</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">게스트 모드로<br>바로 시작해도 돼요.</h2>
            <p class="ob-lede ob-reveal">내 데이터는 이 핸드폰 안에만 있어요. 계정 없어도 모든 기능 다 써요.</p>
            <div class="ob-big-grid">
              <button class="ob-tile ob-reveal ob-tc-indigo" data-action="auth-pick" data-choice="local">
                <div class="ob-tile-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L4 6v6c0 5.25 3.75 10.15 8 11.25C16.25 22.15 20 17.25 20 12V6l-8-4z"/></svg>
                </div>
                <div class="ob-tile-body">
                  <div class="ob-chip">추천</div>
                  <div class="ob-tile-title">게스트 모드</div>
                  <div class="ob-tile-sub">로그인 불필요 · 내 개인 핸드폰에만 저장</div>
                </div>
                <div class="ob-tile-arrow">→</div>
              </button>
              <button class="ob-tile ob-reveal ob-tc-emerald" data-action="auth-pick" data-choice="email">
                <div class="ob-tile-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 2l-8 5-8-5h16zm0 12H4V9l8 5 8-5v9z"/></svg>
                </div>
                <div class="ob-tile-body">
                  <div class="ob-tile-title">병원 이메일로 가입</div>
                  <div class="ob-tile-sub">폰 바꿔도 기록 유지</div>
                </div>
                <div class="ob-tile-arrow">→</div>
              </button>
              <button class="ob-tile ob-reveal ob-tc-azure" data-action="auth-pick" data-choice="google">
                <div class="ob-tile-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                </div>
                <div class="ob-tile-body">
                  <div class="ob-tile-title">Google로 시작</div>
                  <div class="ob-tile-sub">폰 바꿔도 기록 유지</div>
                </div>
                <div class="ob-tile-arrow">→</div>
              </button>
            </div>
          </div>
        </section>

        <!-- 7. JOB (Step 2/4) -->
        <section class="ob-slide ob-ink">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">Step 2 / 4 · 직종</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">간호사세요?</h2>
            <p class="ob-lede ob-reveal">병동 근무표를 올리면 D·E·N·연*·리2가 캘린더에 바로 들어가요. 아니라면 급여명세서로 시작해요.</p>
            <div class="ob-big-grid">
              <button class="ob-tile ob-reveal ob-tc-rose" data-action="job-pick" data-job="nurse">
                <div class="ob-tile-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg>
                </div>
                <div class="ob-tile-body">
                  <div class="ob-tile-title">간호사</div>
                  <div class="ob-tile-sub">엑셀 근무표 → D/E/N·연*·리2 자동 입력</div>
                </div>
                <div class="ob-tile-arrow">→</div>
              </button>
              <button class="ob-tile ob-reveal ob-tc-amber" data-action="job-pick" data-job="other">
                <div class="ob-tile-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h6v6h6v10H6z"/></svg>
                </div>
                <div class="ob-tile-body">
                  <div class="ob-tile-title">그 외 직종</div>
                  <div class="ob-tile-sub">급여명세서 PDF로 시작</div>
                </div>
                <div class="ob-tile-arrow">→</div>
              </button>
            </div>
          </div>
        </section>

        <!-- 8. 업로드 (Step 3/4) -->
        <section class="ob-slide ob-cream" id="ob-upload">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">Step 3 / 4 · 지금 올려도, 나중에 올려도</div>
            <div class="ob-rule ob-reveal"></div>
            <div data-job="nurse">
              <h2 class="ob-display ob-reveal">이번 달<br>근무표 있으세요?</h2>
              <p class="ob-lede ob-reveal">본인 이름이 있는 엑셀 파일 올리면 돼요. D·E·N·AL·RD가 캘린더에 자동으로 들어가요. 나중에 올려도 됩니다.</p>
              <div class="ob-upload-zone ob-reveal">
                <div class="ico">📅</div>
                <div class="t">근무표 올리기</div>
                <div class="s">.xlsx · 파일은 내 기기에만 저장, 서버 전송 없음</div>
              </div>
            </div>
            <div data-job="other" style="display:none">
              <h2 class="ob-display ob-reveal">최근 급여명세서<br>있으세요?</h2>
              <p class="ob-lede ob-reveal">1~3개월치 PDF면 충분해요. 통상임금 계산에 쓰이고, 항목별로 분해해서 보여줘요. 나중에 올려도 됩니다.</p>
              <div class="ob-upload-zone ob-reveal">
                <div class="ico">📄</div>
                <div class="t">명세서 올리기</div>
                <div class="s">PDF 최대 3개 · 파일은 내 기기에만 저장, 서버 전송 없음</div>
              </div>
            </div>
            <div class="ob-cta-row">
              <button class="ob-cta-ghost" data-action="advance">나중에 올릴게요</button>
              <button class="ob-cta-primary" data-action="advance">올리기 →</button>
            </div>
          </div>
        </section>

        <!-- 9. 개인정보 (Step 4/4) -->
        <section class="ob-slide ob-cream" id="ob-profile">
          <div class="ob-inner">
            <div class="ob-index ob-reveal">Step 4 / 4 · 수당 계산에 필요해요</div>
            <div class="ob-rule ob-reveal"></div>
            <h2 class="ob-display ob-reveal">하나씩<br>알려주세요.</h2>
            <div class="ob-pf-stack">
              <div class="ob-pf-field">
                <div class="ob-pf-label">사번</div>
                <input type="text" inputmode="numeric" placeholder="예: 20842" autocomplete="off">
                <div class="ob-pf-hint">호봉 자동 추정에 써요. 없으면 건너뛰어도 돼요.</div>
              </div>
              <div class="ob-pf-field">
                <div class="ob-pf-label">입사일</div>
                <input type="text" inputmode="numeric" placeholder="예: 2021-03-02">
                <div class="ob-pf-hint">연차 일수 자동 계산에 씁니다.</div>
              </div>
              <div class="ob-pf-field">
                <div class="ob-pf-label">직군</div>
                <select>
                  <option>간호직</option>
                  <option>의료기술직</option>
                  <option>사무직</option>
                  <option>기능직</option>
                </select>
                <div class="ob-pf-hint">단협 호봉표가 직군마다 달라요.</div>
              </div>
              <div class="ob-pf-field">
                <div class="ob-pf-label">조정급 (선택)</div>
                <input type="number" placeholder="급여명세서에서 확인">
                <div class="ob-pf-hint">통상임금 계산에 포함돼요. 나중에 입력해도 됩니다.</div>
              </div>
            </div>
            <div class="ob-cta-row">
              <button class="ob-cta-ghost" data-action="pf-back">← 이전</button>
              <button class="ob-cta-primary" data-action="pf-next">다음 →</button>
            </div>
          </div>
        </section>

        <!-- 10. 웰컴 -->
        <section class="ob-slide ob-brand" id="ob-welcome">
          <div class="ob-inner">
            <div class="ob-welcome-check">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h1 class="ob-display" style="margin-top:4px">다 됐어요.<br>이제 직접<br>확인해 보세요.</h1>
            <p class="ob-lede">이번 달 시간외 수당이 맞는지, 연차가 몇 개 남았는지 — 지금 바로 볼 수 있어요.</p>
            <div class="ob-app-grid">
              <div class="ob-app-tile">홈</div>
              <div class="ob-app-tile">급여</div>
              <div class="ob-app-tile">시간외</div>
              <div class="ob-app-tile">휴가</div>
              <div class="ob-app-tile">찾아보기</div>
              <div class="ob-app-tile">설정</div>
            </div>
            <button class="ob-cta-primary" id="ob-start">앱 시작 →</button>
          </div>
        </section>

      </div><!-- /#ob-deck -->
    </div><!-- /.ob-viewport -->

    <!-- Chrome nav -->
    <div class="ob-chrome">
      <button class="ob-nav-btn" id="ob-prev" aria-label="이전">‹</button>
      <div class="ob-progress-track">
        <div class="ob-progress-fill" id="ob-progress"></div>
      </div>
      <div class="ob-counter" id="ob-counter">1 / 10</div>
      <button class="ob-nav-btn" id="ob-next" aria-label="다음">›</button>
    </div>
  </div><!-- /.ob-frame -->

  <script src="/client/onboarding.js" is:inline></script>
</BaseLayout>

<style is:global>
  body > #sharedHeader:empty { display: none; }
</style>
