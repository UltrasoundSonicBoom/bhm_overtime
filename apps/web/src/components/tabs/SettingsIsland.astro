---
// Phase 6 Task 5-5: SettingsIsland.astro
// 기존 apps/web/public/tabs/tab-settings.html 컨텐츠를 Astro component 으로 inline.
// tab-loader.js fetch lazy-load 대신 빌드 시 inline → 콘솔 에러 0 + race 제거.
// CRITICAL: Phase 5-followup-2 fix (commit 6a15385) — <label for="backupFileInput"> 패턴 보존.
//   기존 onclick="triggerBackupFilePicker()" 는 위임 chain 에서 user gesture 손실 → 파일 선택기 안 뜸.
//   사용자 보고 회귀 ("복원 버튼 안 됨"). 루트 레포 public/tabs/tab-settings.html 의 label-for 버전을 사용.
//   apps/web/public/tabs/tab-settings.html 은 옛 버전 (Task 5-3 PayrollIsland buildEmptyState 와 같은 패턴).
// HTML 본문은 root 레포의 fix 적용본 기준 1:1 복사. 수정 금지.
// Phase 7-5: inline style → Tailwind utility.
//   CRITICAL: JS 가 style.display 를 토글하는 element 의 inline style 보존:
//     #appLockStatusBadge, #appLockOff, #appLockOn, #biometricSettingRow, #biometricOn,
//     #teamScheduleSyncSection, #orphanRecoverySection, #orphanRecoveryBody,
//     #backupFileInput (file input 숨김 필수).
//   <label for="backupFileInput"> 패턴 절대 건들지 않음.
---
<div class="tab-content" id="tab-settings">
  <!-- 👤 계정 (Phase 8) — Email + Google 로그인 / 게스트 모드 보존 -->
  <div class="card max-w-[600px] mx-auto" id="snuhmateAuthCard">
    <div class="card-title text-brand-body-large">
      <span class="icon indigo">👤</span> 계정
    </div>
    <div class="flex items-center gap-3">
      <button type="button" id="snuhmateAuthPill" class="btn btn-primary" data-signed-in="0">
        로그인
      </button>
      <button type="button" id="snuhmateLogoutBtn" class="btn btn-outline hidden">
        로그아웃
      </button>
    </div>
    <p class="text-brand-body-normal text-brand-text-muted mt-3 leading-normal">
      로그인 시 다기기 동기화 + 클라우드 백업 활성. 로그인 안 해도 100% 사용 가능합니다.
    </p>
  </div>

  <!-- 🔒 앱 잠금 -->
  <div class="card max-w-[600px] mx-auto" id="appLockSettingsCard">
    <div class="card-title text-brand-body-large">
      <span class="icon indigo">🔒</span> 앱 잠금
      <span id="appLockStatusBadge" class="badge ml-2 bg-[var(--accent-emerald,#10B981)] text-white"
        style="display:none;">켜짐</span>
    </div>
    <p class="text-brand-body-normal text-brand-text-muted mb-3">
      앱을 열 때 PIN 또는 생체인증(Face ID·지문)으로 잠금을 설정해 내 정보를 보호하세요.<br>
      <span class="text-xs">잠금은 이 기기에서만 적용됩니다.</span>
    </p>
    <div id="appLockOff" style="display:block;">
      <button class="btn btn-primary w-full" onclick="onAppLockSetupPin()">
        🔒 PIN 설정하기
      </button>
    </div>
    <div id="appLockOn" style="display:none;">
      <div class="flex flex-wrap gap-2 mb-2.5">
        <button class="btn btn-outline text-brand-body-normal py-1.5 px-3.5" onclick="onAppLockChangePin()">
          🔑 PIN 변경
        </button>
        <button class="btn btn-outline text-brand-body-normal py-1.5 px-3.5 text-brand-accent-rose border-brand-accent-rose" onclick="onAppLockDisable()">
          🔓 잠금 해제
        </button>
      </div>
      <div id="biometricSettingRow" class="mt-2 pt-2.5 border-t border-[var(--border-glass)]"
        style="display:none;">
        <p class="text-brand-body-normal text-brand-text-primary font-semibold mb-1.5">
          생체인증 (Face ID / 지문)</p>
        <div id="biometricOff">
          <button class="btn btn-outline text-brand-body-normal py-1.5 px-3.5" onclick="onBiometricRegister()">
            🪪 생체인증 추가
          </button>
        </div>
        <div id="biometricOn" style="display:none;">
          <span class="badge mr-2 bg-[var(--accent-emerald,#10B981)] text-white">등록됨</span>
          <button class="btn btn-outline text-brand-body-normal py-1 px-2.5 text-brand-accent-rose border-brand-accent-rose" onclick="onBiometricDisable()">
            제거
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- 💾 데이터 백업 및 복구 -->
  <div id="localBackupSection" class="card max-w-[600px] mx-auto mt-5">
    <div class="card-title text-brand-body-large"><span class="icon indigo">💾</span> 데이터 백업 및
      복구</div>
    <p class="text-brand-body-normal text-brand-text-muted mb-3">클라우드 동기화 없이 브라우저 내부에
      저장된 기록을 파일로 안전하게 평생 보관하고 복원할 수 있습니다.</p>
    <div class="form-row [grid-template-columns:1fr_1fr]">
      <button class="btn btn-outline flex-1 font-semibold text-brand-body-normal py-2 px-1" onclick="downloadBackup()">📥 다운로드 (백업)</button>
      <!-- Phase 5-followup-2 fix: <label for=""> 패턴 — 브라우저 native 처리, user gesture 보장 -->
      <!-- 이전 onclick="triggerBackupFilePicker()" 는 위임 chain 에서 user gesture 손실 → file picker 안 뜸 -->
      <label for="backupFileInput" class="btn btn-outline flex-1 font-semibold text-center cursor-pointer text-brand-body-normal py-2 px-1 flex items-center justify-center">
        📤 불러오기 (복원)
      </label>
      <!-- accept 비워둠 — 안드로이드/iOS 사진 폴더 회귀 방지. JS 파일명+내용 검증 -->
      <input type="file" id="backupFileInput" style="display:none"
        onchange="uploadBackup(event)">
    </div>
    <p class="text-brand-text-muted mt-1.5 leading-snug text-[0.7rem]">
      💡 복원 시 <strong>snuh_backup_*.json</strong> 파일을 선택하세요.<br>
      📱 <strong>안드로이드</strong>: "파일" 앱 → "다운로드" 폴더에서 선택 (사진 폴더 X)<br>
      🍎 <strong>iPhone/Safari</strong>: "파일" 앱 → "다운로드"에서 선택<br>
      💻 <strong>크롬/사파리</strong>: 다운로드 폴더에서 자동 표시
    </p>
  </div>

  <!-- 🗓️ 팀 근무표 캘린더 -->
  <div id="teamScheduleSyncSection" class="card max-w-[600px] mx-auto mt-5" style="display:none;">
    <div class="card-title text-brand-body-large">
      <span class="icon indigo">🗓️</span> 팀 근무표 캘린더
    </div>
    <p class="text-brand-body-normal text-brand-text-muted mb-3">
      배포된 팀 근무표가 있으면 이번 달 <strong>D/E/N 근무와 승인 휴가만</strong> `.ics` 파일로 내려받아 일반 캘린더에 가져올 수 있어요.
      Google Calendar 심사 중에는 이 방식으로 테스트합니다.
    </p>
    <div class="info-note-banner mb-3">
      <span>ℹ️</span>
      <span>OFF는 기본 동기화하지 않고, 팀 검토/배포는 팀 워크스페이스에서 진행합니다.</span>
    </div>
    <div class="flex gap-2 flex-wrap">
      <button id="teamScheduleIcsBtn" class="btn btn-outline text-brand-body-normal py-1.5 px-3" onclick="downloadTeamScheduleIcs(this)">📥 이번 달 근무표 .ics 받기</button>
      <a class="btn btn-outline text-brand-body-normal py-1.5 px-3 no-underline" href="./nurse_admin/index.html">배포 근무표 열기</a>
      <a class="btn btn-outline text-brand-body-normal py-1.5 px-3 no-underline" href="./nurse_admin/admin.html">관리자판 열기</a>
      <a class="btn btn-outline text-brand-body-normal py-1.5 px-3 no-underline" href="./dashboard.html">검증 대시보드</a>
    </div>
    <p id="teamScheduleSyncNote" class="text-xs text-brand-text-muted mt-2">
      팀 로그인 후 사용할 수 있어요.
    </p>
  </div>

  <!-- ⚠️ 데이터 충돌 복구 -->
  <div id="orphanRecoverySection" class="card max-w-[600px] mx-auto mt-5" style="display:none;">
    <div class="collapsible-header mb-0" onclick="toggleCollapsible('orphanRecoveryBody')">
      <span class="flex items-center gap-2" id="orphanRecoveryToggleLabel">
        <span class="toggle-icon">▸</span>
        <span class="icon text-[color:var(--accent-amber)]">⚠️</span>
        <span class="text-brand-body-large font-semibold">충돌 백업 복구</span>
        <span id="orphanCountBadge" class="badge text-white bg-[var(--accent-amber)]"></span>
      </span>
    </div>
    <div class="collapsible-body" id="orphanRecoveryBody" style="display:none;">
      <p class="text-brand-body-normal text-brand-text-muted mt-2 mb-3 leading-normal">
        기기 전환 또는 동기화 충돌 때 자동 보관된 이전 데이터 사본입니다.<br>
        현재 데이터 대신 복구하거나, 확인 후 삭제할 수 있어요.
      </p>
      <div id="orphanList" class="flex flex-col gap-2"></div>
    </div>
  </div>

  <!-- ── Desktop right-context panel (≥1280px only) ── -->
  <aside class="tab-desktop-context" aria-label="설정 컨텍스트">
    <div class="ds-ctx-section">실시간 컨텍스트 · 설정</div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">💾 백업 상태</div>
      <div class="ds-ctx-row"><span class="k">로컬</span><span class="v ds-ctx-value-emerald" id="settingsCtxLocal">실시간</span></div>
      <div class="ds-ctx-row"><span class="k">Firebase</span><span class="v" id="settingsCtxFirebase">—</span></div>
      <div class="ds-ctx-row"><span class="k">Google Drive</span><span class="v" id="settingsCtxDrive">—</span></div>
      <div class="ds-ctx-row"><span class="k">크기</span><span class="v" id="settingsCtxSize">—</span></div>
    </div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">📱 등록된 디바이스 <small id="settingsCtxDevCount">—</small></div>
      <div id="settingsCtxDevices" class="ds-ctx-note">—</div>
    </div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">🛡️ 개인정보 처리</div>
      <div class="ds-ctx-note-plain">민감정보는 <b>본인 기기에만 저장</b>. 동의한 항목만 동기화.</div>
      <div class="ds-ctx-row ds-ctx-row-spaced"><a class="ds-ctx-link" href="/terms" target="_blank">이용약관 →</a></div>
      <div class="ds-ctx-row"><a class="ds-ctx-link" href="/privacy" target="_blank">개인정보처리방침 →</a></div>
    </div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">ℹ️ 앱 정보</div>
      <div class="ds-ctx-row"><span class="k">버전</span><span class="v">v2.4.1</span></div>
      <div class="ds-ctx-row"><span class="k">빌드</span><span class="v" id="settingsCtxBuild">—</span></div>
    </div>
  </aside>
</div>

<script>
  // Phase 8 Task 5 — Auth UI mount (Settings 탭)
  // SDK 가 gstatic CDN ESM 이라 빌드 후에도 외부 import 유지 — Vite 가 처리하지 않도록 dynamic import.
  // firebaseConfig.apiKey 가 없으면 (env vars 미설정) Firebase 비활성 — pill 클릭 시 무해 알림.
  document.addEventListener('DOMContentLoaded', async () => {
    const pill = document.getElementById('snuhmateAuthPill');
    const logoutBtn = document.getElementById('snuhmateLogoutBtn');
    if (!pill) return;

    try {
      // config.js 의 firebaseConfig 로 초기화 가능 여부 체크
      const { firebaseConfig } = await import('../../client/config.js');
      if (!firebaseConfig?.apiKey) {
        pill.textContent = '로그인 (env 미설정)';
        pill.dataset.signedIn = '0';
        return;
      }

      const { openAuthDialog, bindAuthPill, logout } = await import('../../firebase/auth-ui.js');
      bindAuthPill(pill);
      pill.addEventListener('click', () => {
        if (pill.dataset.signedIn === '0') openAuthDialog();
      });
      logoutBtn?.addEventListener('click', () => logout());

      // pill 상태 변화 → logout 버튼 표시 토글
      window.addEventListener('app:auth-changed', () => {
        if (pill.dataset.signedIn === '1') logoutBtn?.classList.remove('hidden');
        else logoutBtn?.classList.add('hidden');
      });
    } catch (e) {
      const message = e instanceof Error ? e.message : String(e);
      console.warn('[Phase 8] auth UI init 실패 (무해, 게스트 모드 유지)', message);
    }
  });
</script>
