  ].join('\n');

  /* ── Sub-tab 전환 ────────────────────────────────────────── */
  function initTabs() {
    var tabs = document.querySelectorAll('#tab-ai .ai-btab');
    var panels = document.querySelectorAll('#tab-ai .ai-panel');
    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-aitab');
        tabs.forEach(function (b) { b.classList.remove('active'); });
        panels.forEach(function (p) { p.classList.remove('active'); });
        btn.classList.add('active');
        var panel = document.getElementById('ai-panel-' + target);
        if (panel) {
          panel.classList.add('active');
          requestAnimationFrame(function () { observePanel(panel); });
        }
      });
    });
  }

  /* ── IntersectionObserver 카드 등장 ─────────────────────── */
  function observePanel(panel) {
    var cards = panel.querySelectorAll('.ai-idea-card, .ai-pcard');
    if (!cards.length) return;
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('ai-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });
    cards.forEach(function (card) { obs.observe(card); });
  }

  /* ── Blob 다운로드 ───────────────────────────────────────── */
  function initDownload() {
    var btn = document.getElementById('aiDownloadBtn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var blob = new Blob([BUNDLE], { type: 'text/markdown;charset=utf-8' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'snuhmate-harness-bundle.md';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });
  }

  /* ── 초기화 ─────────────────────────────────────────────── */
  function init() {
    initTabs();
    initDownload();
    var bp = document.getElementById('ai-panel-blueprint');
    if (bp) requestAnimationFrame(function () { observePanel(bp); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
