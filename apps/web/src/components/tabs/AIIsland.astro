</style>

<script>
// @ts-nocheck
(function () {

  /* ── Sub-tab 전환 ────────────────────────────────────────── */
  function initTabs() {
    var tabs = document.querySelectorAll('#tab-ai .ai-btab');
    var panels = document.querySelectorAll('#tab-ai .ai-panel');
    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-aitab');
        tabs.forEach(function (b) { b.classList.remove('active'); });
        panels.forEach(function (p) { p.classList.remove('active'); });
        btn.classList.add('active');
        var panel = document.getElementById('ai-panel-' + target);
        if (panel) {
          panel.classList.add('active');
          requestAnimationFrame(function () { observePanel(panel); });
        }
      });
    });
  }

  /* ── IntersectionObserver 카드 등장 ─────────────────────── */
  function observePanel(panel) {
    var cards = panel.querySelectorAll('.ai-bpcard, .ai-pcard');
    if (!cards.length) return;
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('ai-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.04 });
    cards.forEach(function (card) { obs.observe(card); });
  }

  /* ── 페르소나 필터 ───────────────────────────────────────── */
  function initPersonaFilter() {
    var chips = document.querySelectorAll('#tab-ai .ai-pchip');
    chips.forEach(function (chip) {
      chip.addEventListener('click', function () {
        chips.forEach(function (c) { c.classList.remove('active'); });
        chip.classList.add('active');
        var persona = chip.getAttribute('data-persona');
        filterByPersona(persona);
      });
    });
  }

  function filterByPersona(persona) {
    var allCards = document.querySelectorAll('#tab-ai .ai-bpcard');
    allCards.forEach(function (card) {
      if (persona === 'all') {
        card.classList.remove('ai-card-hidden');
      } else {
        var personas = (card.getAttribute('data-personas') || '').split(' ');
        if (personas.indexOf(persona) !== -1) {
          card.classList.remove('ai-card-hidden');
        } else {
          card.classList.add('ai-card-hidden');
        }
      }
    });
    // 모든 카드가 숨겨진 섹션은 숨김
    var groups = document.querySelectorAll('#tab-ai .ai-section-group');
    groups.forEach(function (grp) {
      var visible = grp.querySelectorAll('.ai-bpcard:not(.ai-card-hidden)');
      if (visible.length === 0) {
        grp.classList.add('ai-sec-hidden');
      } else {
        grp.classList.remove('ai-sec-hidden');
      }
    });
  }

  /* ── 카드별 하네스 다운로드 ──────────────────────────────── */
  function initCardDownloads() {
    var btns = document.querySelectorAll('#tab-ai .ai-card-dl');
    btns.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var skillKey = btn.getAttribute('data-skill');
        if (!skillKey) return;
        var url = '/harness/' + skillKey + '.md';
        fetch(url)
          .then(function (res) {
            if (!res.ok) throw new Error('not found');
            return res.text();
          })
          .then(function (text) {
            var blob = new Blob([text], { type: 'text/markdown;charset=utf-8' });
            var burl = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = burl;
            a.download = 'snuhmate-' + skillKey + '.md';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(burl);
          })
          .catch(function () {
            window.open(url, '_blank');
          });
      });
    });
  }

  /* ── 초기화 ─────────────────────────────────────────────── */
  function init() {
    initTabs();
    initPersonaFilter();
    initCardDownloads();
    var bp = document.getElementById('ai-panel-blueprint');
    if (bp) requestAnimationFrame(function () { observePanel(bp); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
