---
// Phase 6 Task 5-2: ProfileIsland.astro
// 기존 apps/web/public/tabs/tab-profile.html 컨텐츠를 Astro component 으로 inline.
// tab-loader.js 의 fetch lazy-load 대신 빌드 시 inline → 콘솔 에러 0 + race 제거.
// initProfileTab() / _refreshProfile() 등은 profile-tab.js 에서 그대로 호출 (tab 진입 시).
// HTML 본문은 tab-profile.html 에서 1:1 복사. 수정 금지.
// Phase 5-followup form 자동 반영 fix + Plan 2 lazy migration 모두 보존.
---
<div class="tab-content" id="tab-profile">
  <!-- 책갈피 (개인 정보 / 근무 정보) -->
  <nav class="pay-bookmark-tabs" id="profileBookmarkBar" role="tablist" aria-label="정보 구분">
    <button id="bmPersonal" class="pay-bookmark-tab active" data-subtab="profile-personal" role="tab"
      aria-selected="true" onclick="switchProfileSection('personal')">👤 개인 정보</button>
    <button id="bmWork" class="pay-bookmark-tab" data-subtab="profile-work" role="tab" aria-selected="false"
      onclick="switchProfileSection('work')">💼 근무 정보</button>
  </nav>
  <div class="pay-tab-accent bg-[#4f46e5]" id="profileTabAccent"></div>

  <div id="profileSectionPersonal">
    <div class="card max-w-[600px] mx-auto">
      <div class="card-title"><span class="icon indigo">👤</span> <span id="pfTitleName">내 정보</span>
        <span class="badge emerald" id="profileStatus">미저장</span>
      </div>

      <!-- 급여탭 안내 링크 (PDF 배너 대체) -->
      <div id="pfPayslipLink" onclick="if(window.switchTab)switchTab('payroll');"
        class="flex items-center gap-2.5 py-2.5 px-3.5 mb-3.5 border-2 border-brand-accent-indigo rounded-lg cursor-pointer text-brand-body-normal font-semibold text-brand-accent-indigo bg-[rgba(99,102,241,0.08)]">
        <span class="text-[1.2rem]">💰</span>
        <span>급여 탭에서 명세서를 등록하면 자동으로 채워집니다</span>
        <span class="ml-auto">→</span>
      </div>
      <!-- 자동갱신 상태 배너 (JS에서 표시) -->
      <div id="pfAutoSyncBanner"
        class="items-center gap-2 px-3.5 py-2 mb-2.5 bg-[rgba(16,185,129,0.08)] border border-[var(--accent-emerald)] rounded-lg text-brand-body-small font-semibold text-[var(--accent-emerald)]"
        style="display:none;">
        <span>✅</span> <span id="pfAutoSyncText">명세서 기준 자동 갱신됨</span>
      </div>

      <!-- pfInputFields 래퍼 유지 (CSS 셀렉터 호환) -->
      <div id="pfInputFields">
        <span id="pfInputToggleLabel" style="display:none;">내 정보 입력/수정</span>

        <!-- ▸ 기본 정보 (토글 아코디언) -->
        <div class="collapsible-header" onclick="toggleCollapsible('pfBasicFields')" id="pfBasicHeader">
          <span class="flex items-center gap-2">
            <span class="toggle-icon">▸</span> 기본 정보
            <span id="pfBasicBadge" class="badge emerald text-[10px]" style="display:none;">저장됨</span>
          </span>
        </div>
        <div id="pfBasicPreview"
          class="px-3.5 py-1.5 text-brand-body-small text-[var(--text-muted)] font-semibold bg-[var(--bg-hover)] rounded-b-lg -mt-px cursor-pointer"
          style="display:none;"
          onclick="toggleCollapsible('pfBasicFields')"></div>
        <div class="collapsible-body" id="pfBasicFields" style="display:none;">
          <div class="form-row">
            <div class="form-group">
              <label>이름 (별칭)</label>
              <input type="text" id="pfName" placeholder="예: 홍길동" autocomplete="off">
            </div>
            <div class="form-group">
              <label class="whitespace-nowrap">성별 <small class="text-brand-text-muted">(생휴 여부)</small></label>
              <select id="pfGender">
                <option value="">미설정</option>
                <option value="M">남성</option>
                <option value="F">여성</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="whitespace-nowrap">생년월일 <small class="text-brand-text-muted">(정년 산정)</small></label>
              <input type="date" id="pfBirthDate" oninput="syncBirthDateToRetirement(this.value)">
            </div>
            <div class="form-group">
              <label>부서</label>
              <input type="text" id="pfDepartment" placeholder="예: 핵의학과, 중환자실" autocomplete="off">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>직종</label>
              <select id="pfJobType" onchange="updateProfileGrades()"></select>
            </div>
            <div class="form-group">
              <label>직급·등급</label>
              <select id="pfGrade" onchange="_suggestYear(document.getElementById('pfHireDate').value)"></select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>입사일</label>
              <input type="text" id="pfHireDate" placeholder="예: 2021-01-01">
              <small id="pfServiceDisplay" class="text-brand-text-muted"></small>
            </div>
            <div class="form-group">
              <label>호봉 (연차)</label>
              <select id="pfYear">
                <option value="1">1년차</option>
                <option value="2">2년차</option>
                <option value="3">3년차</option>
                <option value="4">4년차</option>
                <option value="5">5년차</option>
                <option value="6">6년차</option>
                <option value="7">7년차</option>
                <option value="8">8년차</option>
              </select>
              <small id="pfYearHint" class="text-brand-text-muted"></small>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>사번</label>
              <input type="text" id="pfEmployeeNumber" placeholder="예: 20842" autocomplete="off"
                inputmode="numeric">
            </div>
            <div class="form-group">
              <label>조정급 (필수!!)</label>
              <input type="number" id="pfAdjust" value="0" placeholder="급여명세서 확인">
            </div>
          </div>
        </div><!-- /pfBasicFields -->

        <!-- ▸ 가족 수당 (아코디언) -->
        <div class="collapsible-header mt-2" onclick="toggleCollapsible('pfFamilyFields')">
          <span class="flex items-center gap-2">
            <span class="toggle-icon">▸</span> 가족 수당 <small
              class="font-normal text-brand-text-muted ml-1">통상임금 미포함 · 별도 지급</small>
          </span>
        </div>
        <div class="collapsible-body" id="pfFamilyFields" style="display:none;">
          <div class="form-row profile-row-solo">
            <div class="form-group">
              <label>가족 수 <small class="text-brand-text-muted">(자녀 제외·최대 5인)</small></label>
              <input type="number" id="pfFamily" value="0" min="0" max="5" onchange="updateFamilyUI()"
                oninput="updateFamilyUI()">
              <small class="text-brand-text-muted">배우자 4만원 / 추가 1인당 2만원</small>
            </div>
          </div>
          <div id="pfChildrenRow" class="form-row" style="display:none;">
            <div class="form-group">
              <label>자녀 수</label>
              <input type="number" id="pfChildren" value="0" min="0" max="10" onchange="updateFamilyUI()"
                oninput="updateFamilyUI()">
              <small class="text-brand-text-muted">첫째 3만 / 둘째 7만 / 셋째이상 11만</small>
            </div>
          </div>
          <div id="childExtraRow" class="form-row" style="display:none;">
            <div class="form-group">
              <label>6세이하 자녀수당 <small class="text-brand-text-muted">(월액 직접 입력)</small></label>
              <input type="number" id="pfChildrenUnder6Pay" value="0" min="0" step="10000" placeholder="급여명세서 확인"
                onchange="updateFamilyUI()" oninput="updateFamilyUI()">
              <small class="text-brand-text-muted">급여명세서의 6세이하자녀수당 금액 그대로 입력</small>
            </div>
          </div>
          <div id="pfFamilySummary"
            class="mt-1 px-3 py-2 bg-[var(--bg-hover)] rounded-lg text-brand-body-small"
            style="display:none;">
          </div>
        </div>

        <!-- ▸ 개인 수당 (아코디언) -->
        <div class="collapsible-header mt-4" onclick="toggleCollapsible('pfAllowanceFields')">
          <span class="flex items-center gap-2">
            <span class="toggle-icon">▸</span> 개인 수당 <small
              class="font-normal text-brand-text-muted ml-1">5개</small>
          </span>
        </div>
        <div class="collapsible-body" id="pfAllowanceFields" style="display:none;">
          <div class="form-row">
            <div class="form-group">
              <label>승급조정급</label>
              <input type="number" id="pfUpgradeAdjust" value="0">
            </div>
            <div class="form-group">
              <label>별정수당</label>
              <input type="number" id="pfSpecial" value="0" min="0">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>직책급</label>
              <input type="number" id="pfPosition" value="0" min="0">
            </div>
            <div class="form-group">
              <label>업무보조비</label>
              <input type="number" id="pfWorkSupport" value="0" min="0">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>군복무수당</label>
              <div class="toggle-group mt-1.5">
                <input type="checkbox" id="pfMilitary">
                <label for="pfMilitary">해당 있음</label>
              </div>
              <div id="pfMilitaryMonthsGroup" class="mt-1.5" style="display:none;">
                <input type="number" id="pfMilitaryMonths" value="24" min="1" max="36" placeholder="복무기간(개월)">
              </div>
            </div>
          </div>
        </div>

        <!-- ▸ 고급 설정 (아코디언) -->
        <div class="collapsible-header mt-2" onclick="toggleCollapsible('pfAdvancedFields')">
          <span class="flex items-center gap-2">
            <span class="toggle-icon">▸</span> 고급 설정 <small
              class="font-normal text-brand-text-muted ml-1">승진일·호봉보정·근로시간</small>
          </span>
        </div>
        <div class="collapsible-body" id="pfAdvancedFields" style="display:none;">
          <div class="form-row">
            <div class="form-group">
              <label>최근 승진일 <small class="font-normal text-brand-text-muted">선택</small></label>
              <input type="text" id="pfPromotionDate" placeholder="예: 2024-03-01">
              <small id="pfPromotionHint" class="text-brand-text-muted"></small>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>노조협의 호봉 보정 <small class="font-normal text-brand-text-muted">선택</small></label>
              <select id="pfUnionStepAdjust">
                <option value="">자동 (직급 기준 자동 적용)</option>
                <option value="0">0 — 해당 없음</option>
                <option value="1">+1호봉 (수동 지정)</option>
                <option value="2">+2호봉 (수동 지정)</option>
              </select>
              <small class="text-brand-text-muted">2026.02 노조협의: J1~S1 +1호봉 자동 적용</small>
            </div>
          </div>
          <div class="form-row profile-row-solo">
            <div class="form-group">
              <label>월 소정근로시간 <small class="font-normal text-brand-text-muted">기본 209h</small></label>
              <input type="number" id="pfWeeklyHours" value="209" min="1" max="300" placeholder="209">
              <small class="text-brand-text-muted">시급 계산 기준 · 일반 전일제 근무자는 209h 그대로</small>
            </div>
            <div class="form-group"></div>
          </div>
        </div>

        <input type="checkbox" id="pfSeniority" class="hidden">

        <!-- 공용 기기 개인정보 주의 안내 -->
        <div
          class="flex items-start gap-2.5 py-2.5 px-3 rounded-lg text-brand-body-normal mt-5 leading-[1.5] bg-[rgba(245,158,11,0.09)] border border-[rgba(245,158,11,0.35)]">
          <span class="text-[1.1rem] shrink-0 mt-px">⚠️</span>
          <div>
            <strong class="font-bold block mb-0.5 text-[#F080A0]">공용 기기에서는 개인정보를 저장하지
              마세요</strong>
            <span class="text-brand-text-secondary">학교·도서관·직장 공용 컴퓨터에서는 개인정보를 입력하지 마세요. 데이터는 이 브라우저에만 저장되어
              <strong>다음 사용자가 동일 브라우저를 열면 볼 수 있습니다.</strong></span>
          </div>
        </div>

        <div class="form-row profile-action-row mt-4">
          <button class="btn btn-primary flex-[2]" onclick="saveProfile()">💾 저장하기</button>
          <button class="btn btn-outline flex-1" onclick="clearProfile()">🗑 초기화</button>
        </div>
        <div id="profileSavedCTA"
          class="mt-3.5 px-4 py-3 bg-[rgba(52,211,153,0.1)] border border-[rgba(52,211,153,0.3)] rounded-lg text-center"
          style="display:none;">
          <p id="profileSavedCTADesc"
            class="text-brand-body-small text-[var(--text-muted)] mb-2 mt-0">정보가 저장됐어요. 이번 달 시간외
            수당을 계산해볼까요?</p>
          <button id="profileSavedCTABtn" onclick="switchTab('overtime')" class="btn btn-primary w-full">⏰ 시간외 계산하러 가기 →</button>
        </div>

      </div><!-- /pfInputFields -->
    </div><!-- End of Profile Form Card -->

    <!-- 프로필 요약 -->
    <div id="profileSummary" class="card max-w-[600px] mx-auto mt-5">
      <div class="card-title text-brand-body-large"><span class="icon indigo">📝</span> 통상임금 내역
      </div>
      <p class="text-brand-text-muted">정보를 입력하고 [저장하기]를 눌러주세요.</p>
    </div>

  </div><!-- /profileSectionPersonal -->

  <div id="profileSectionWork" style="display:none;">
    <!-- E1: 근무이력 섹션 -->
    <div class="card max-w-[600px] mx-auto" id="workHistoryCard">
      <div class="flex items-center justify-between mb-3">
        <div class="card-title text-brand-body-large m-0">
          <span class="icon indigo">💼</span> 근무이력
        </div>
        <button id="addWorkHistoryBtn" class="btn btn-primary py-1.5 px-3.5 text-brand-body-small"
          onclick="openWorkHistorySheet({__newPost:true})">+ 근무지 추가</button>
      </div>
      <!-- Phase 4-A: 명세서 시계열 → 근무이력 알림 배너 (mode='banner' 시) -->
      <div id="workHistoryBanner" class="mb-3" style="display:none;"></div>
      <div id="workHistoryList"></div>
    </div>

    <!-- 근무이력 입력 바텀시트 -->
    <div id="workHistorySheet" style="display:none; position:fixed; inset:0; z-index:9000;
       background:rgba(0,0,0,0.5);" onclick="if(event.target===this)closeWorkHistorySheet()">
      <div class="absolute bottom-0 left-0 right-0 max-w-[480px] mx-auto rounded-t-2xl pt-5 px-4 pb-8 max-h-[85vh] overflow-y-auto bg-[var(--bg-card,#fff)]">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-2 flex-1 min-w-0">
            <span class="text-brand-body-large font-semibold" id="workHistorySheetTitle">근무이력
              추가</span>
            <span id="workHistorySheetBadge"
              class="text-[0.68rem] font-bold px-2 py-[3px] rounded-[10px] bg-[rgba(245,158,11,.15)] text-[#d97706]"
              style="display:none;"></span>
          </div>
          <button onclick="closeWorkHistorySheet()"
            class="bg-transparent border-0 text-[1.4rem] cursor-pointer leading-none py-1 px-2">×</button>
        </div>
        <input type="hidden" id="whEditId" value="">
        <div class="flex flex-col gap-3">
          <div>
            <label class="text-brand-body-small font-semibold block mb-1">직장명
              *</label>
            <input id="whWorkplace" type="text" placeholder="예: 서울대학교병원" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal">
          </div>
          <div>
            <label class="text-brand-body-small font-semibold block mb-1">부서명
              *</label>
            <input id="whDept" type="text" placeholder="예: 핵의학과, 중환자실, 101병동" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal">
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-brand-body-small font-semibold block mb-1">시작
                (년-월)</label>
              <input id="whFrom" type="month" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal">
              <small id="whFromHint"
                class="block mt-1 text-[var(--accent-amber,#d97706)] text-[0.7rem]"
                style="display:none;"></small>
            </div>
            <div>
              <label class="text-brand-body-small font-semibold block mb-1">종료
                (년-월)</label>
              <input id="whTo" type="month" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal" placeholder="재직 중이면 빈칸">
            </div>
          </div>
          <div>
            <label
              class="text-brand-body-small font-semibold block mb-1">직무</label>
            <input id="whRole" type="text" list="whRoleSuggestions" placeholder="직종에 따라 자동 추천됩니다" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal">
            <datalist id="whRoleSuggestions"></datalist>
            <small id="whRoleHint"
              class="block mt-1 text-brand-text-muted text-[0.72rem]"></small>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-brand-body-small font-semibold">주요 역할 (선택)</label>
              <button type="button" onclick="autofillJobDesc()" id="whAutofillBtn" class="text-[0.7rem] py-[3px] px-2 border border-brand-accent-indigo text-brand-accent-indigo rounded-md cursor-pointer bg-[rgba(99,102,241,.08)]">✨ 표준 업무 자동 채움</button>
            </div>
            <textarea id="whDesc" rows="4" placeholder="간략한 업무 내용..."
              class="w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal resize-none"></textarea>
          </div>
          <button class="btn btn-primary w-full py-3"
            onclick="saveWorkHistoryEntry()">저장</button>
        </div>
      </div>
    </div>


    <!-- 이력서 섹션 입력 바텀시트 (학력/자격/논문 공용) -->
    <div id="resumeItemSheet" style="display:none; position:fixed; inset:0; z-index:9100;
       background:rgba(0,0,0,0.5);" onclick="if(event.target===this)closeResumeItemSheet()">
      <div class="absolute bottom-0 left-0 right-0 max-w-[480px] mx-auto rounded-t-2xl pt-5 px-4 pb-8 max-h-[85vh] overflow-y-auto bg-[var(--bg-card,#fff)]">
        <div class="flex items-center justify-between mb-3.5">
          <span class="text-brand-body-large font-semibold" id="resumeItemSheetTitle">항목 추가</span>
          <button onclick="closeResumeItemSheet()"
            class="bg-transparent border-0 text-[1.4rem] cursor-pointer leading-none py-1 px-2">×</button>
        </div>
        <div id="resumeItemFields" class="flex flex-col gap-3"></div>
        <button class="btn btn-primary w-full py-3 mt-3"
          onclick="saveResumeItem()">저장</button>
      </div>
    </div>

    <!-- 로테이션 입력 바텀시트 -->
    <div id="rotationSheet" style="display:none; position:fixed; inset:0; z-index:9100;
       background:rgba(0,0,0,0.5);" onclick="if(event.target===this)closeRotationSheet()">
      <div class="absolute bottom-0 left-0 right-0 max-w-[480px] mx-auto rounded-t-2xl pt-5 px-4 pb-8 max-h-[85vh] overflow-y-auto bg-[var(--bg-card,#fff)]">
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-brand-body-large font-semibold" id="rotationSheetTitle">로테이션 추가</span>
          <button onclick="closeRotationSheet()"
            class="bg-transparent border-0 text-[1.4rem] cursor-pointer leading-none py-1 px-2">×</button>
        </div>
        <p id="rotationParentHint" class="text-[0.72rem] text-brand-text-muted m-0 mb-3.5"></p>
        <div class="flex flex-col gap-3">
          <div>
            <label class="text-brand-body-small font-semibold block mb-1">근무방
              / 파트 *</label>
            <input id="rotRoom" type="text" placeholder="예: PET실, 감마실, 갑상선치료실" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal">
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-brand-body-small font-semibold block mb-1">시작
                (년-월)</label>
              <input id="rotFrom" type="month" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal">
            </div>
            <div>
              <label class="text-brand-body-small font-semibold block mb-1">종료
                (년-월)</label>
              <input id="rotTo" type="month" class="form-input w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal" placeholder="진행 중이면 빈칸">
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-brand-body-small font-semibold">수행 업무 (선택)</label>
              <button type="button" onclick="autofillRotationTasks()" class="text-[0.7rem] py-[3px] px-2 border border-brand-accent-indigo text-brand-accent-indigo rounded-md cursor-pointer bg-[rgba(99,102,241,.08)]">✨ 표준 업무 자동 채움</button>
            </div>
            <textarea id="rotTasks" rows="4"
              placeholder="줄바꿈으로 항목 구분&#10;예: PET-CT 검사 진행&#10;FDG 합성 보조&#10;환자 안내 및 교육"
              class="w-full py-2.5 px-3 border border-brand-border-glass rounded-lg text-brand-body-normal resize-y"></textarea>
          </div>
          <div id="rotActions" class="grid grid-cols-1 gap-2">
            <button id="rotDeleteBtn" type="button"
              class="w-full py-3 px-3 border border-[var(--accent-rose,#f43f5e)] text-[var(--accent-rose,#f43f5e)] bg-transparent rounded-lg font-semibold cursor-pointer"
              style="display:none;"
              onclick="deleteRotationEntry()">삭제</button>
            <button id="rotSaveBtn" class="btn btn-primary w-full py-3"
              onclick="saveRotationEntry()">저장</button>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /profileSectionWork -->
</div>
