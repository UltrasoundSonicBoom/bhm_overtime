---
// Phase 6 Task 5-4: LeaveIsland.astro
// 기존 apps/web/public/tabs/tab-leave.html 컨텐츠를 Astro component 으로 inline.
// tab-loader.js 의 fetch lazy-load 대신 빌드 시 inline → 콘솔 에러 0 + race 제거.
// 기존 initLeaveTab() 함수는 app.js 에서 그대로 호출 (tab 진입 시).
// HTML 본문은 tab-leave.html 에서 1:1 복사. 수정 금지.
---
<div class="tab-content" id="tab-leave">
  <!-- 연차 기준 안내 배너 -->
  <div class="info-note-banner" id="lvAnnualInfoNote">
    <span>📌</span>
    <span>연차 일수는 <a onclick="switchTab('profile')">개인정보 탭</a>의 <strong>입사일</strong> 기준으로 자동 산정됩니다. 입사일이 미입력이면 연차 현황이
      표시되지 않을 수 있어요.</span>
  </div>

  <!-- 캘린더 -->
  <div class="card p-3">
    <div id="lvCalendar"></div>
  </div>

  <!-- 휴가 입력 바텀시트 (시간외·온콜과 동일한 UX) -->
  <div id="lvInputOverlay" class="ot-bottom-sheet-overlay" onclick="closeLvBottomSheet()"></div>
  <div id="lvInputSheet" class="ot-bottom-sheet">
    <div class="ot-sheet-handle"></div>
    <div class="flex justify-between items-center mb-2">
      <span id="lvPanelDate" class="font-bold text-brand-title-large text-brand-text-primary">날짜를 선택하세요</span>
      <button class="btn btn-icon p-1 text-brand-title-large bg-none border-none cursor-pointer" onclick="closeLvBottomSheet()">
        <span class="text-brand-text-muted">✕</span>
      </button>
    </div>

    <div class="form-group mt-2.5">
      <label>휴가 유형</label>
      <input type="hidden" id="lvType" value="annual">
      <button id="lvTypeBtn" type="button"
        class="btn w-full h-11 text-left bg-brand-bg-glass border border-brand-border-glass rounded-brand-sm text-brand-text-primary text-brand-body-large px-3.5 py-0 flex justify-between items-center"
        onclick="openLvTypeBottomSheet()">
        <span id="lvTypeBtnText">🏖️ 연차</span>
        <span class="text-brand-text-muted text-sm font-mono">▼</span>
      </button>
    </div>

    <!-- 시간차 시간 입력 -->
    <div id="lvTimeInputArea"
      class="mb-2.5 p-2.5 rounded-lg border"
      style="display:none; background:rgba(16,185,129,0.05); border-color:rgba(16,185,129,0.15);">
      <label class="block text-brand-body-large font-semibold text-brand-accent-emerald mb-1.5">시간 설정</label>
      <div class="flex flex-row gap-2 items-center mb-2">
        <input type="time" id="lvStartTime" class="time-picker-premium flex-1 w-full" value="09:00"
          onchange="calcLvTimeHours()">
        <span class="text-brand-text-muted font-bold">~</span>
        <input type="time" id="lvEndTime" class="time-picker-premium flex-1 w-full" value="13:00"
          onchange="calcLvTimeHours()">
      </div>
      <div id="lvTimeCalcResult"
        class="text-brand-body-large py-1.5 px-2 rounded-md text-brand-accent-indigo font-semibold text-center bg-[rgba(99,102,241,0.08)]">
      </div>
    </div>

    <!-- 청원/경조 상세정보 패널 -->
    <div id="lvCeremonyInfo"
      class="mb-2.5 p-2.5 rounded-lg border text-brand-body-large"
      style="display:none; background:rgba(251,191,36,0.06); border-color:rgba(251,191,36,0.2);">
      <div class="font-semibold mb-1.5 text-black">📋 청원휴가 안내</div>
      <div id="lvCeremonyDays" class="mb-[3px]"></div>
      <div id="lvCeremonyPay" class="mb-[3px]"></div>
      <div id="lvCeremonyDocs" class="mb-[3px]"></div>
      <div id="lvCeremonyExtra" class="text-brand-accent-indigo"></div>
    </div>

    <!-- 한도 현황 뱃지 -->
    <div id="lvQuotaBadge" class="mb-2.5" style="display:none;"></div>

    <div class="form-row" id="lvDateFields">
      <input type="hidden" id="lvStartDate">
      <div class="form-group w-full">
        <label>종료일 <small class="text-brand-text-muted font-normal">(선택한 날짜부터)</small></label>
        <input type="date" id="lvEndDate">
      </div>
    </div>

    <!-- 급여 영향 미리보기 -->
    <div id="lvPreview" class="ot-preview"></div>
    <div class="form-group">
      <label>메모 (선택)</label>
      <input type="text" id="lvMemo" placeholder="예: 개인사유">
    </div>

    <div class="flex flex-row mt-4 gap-3">
      <button class="btn btn-outline flex-1 border-transparent text-brand-accent-rose text-brand-body-large font-semibold p-3.5 justify-center rounded-xl transition-all duration-200" onclick="deleteLvRecord()"
        style="display:none; background:rgba(244,63,94,0.08);"
        id="lvDeleteBtn">삭제</button>
      <button class="btn btn-primary flex-1 text-brand-title-large p-3.5 justify-center rounded-xl" onclick="saveLvRecord()"
        id="lvSaveBtn">저장</button>
    </div>
    <input type="hidden" id="lvEditId" value="">
  </div>
  <!-- 휴가 유형 선택 네오브루탈리즘 바텀시트 -->
  <div id="lvTypeSelectOverlay" class="ot-bottom-sheet-overlay z-[10001]" onclick="closeLvTypeBottomSheet()"></div>
  <div id="lvTypeSelectSheet" class="ot-bottom-sheet z-[10002] pt-5 px-4 pb-[30px] max-h-[80vh]">
    <div class="ot-sheet-handle"></div>
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-brand-title-large m-0 font-bold text-brand-text-primary">휴가 유형 선택</h3>
      <button class="btn btn-icon p-1 text-brand-title-large bg-none border-none cursor-pointer" onclick="closeLvTypeBottomSheet()">
        <span class="text-brand-text-muted">✕</span>
      </button>
    </div>
    <div id="lvTypeSelectContainer" class="max-h-[65vh] overflow-y-auto flex flex-col gap-1.5 -mx-2 px-2">
      <!-- JS 렌더링 영역 -->
    </div>
  </div>
  <!-- 하단: 사용내역 + 소진현황 -->
  <div class="grid-2 items-start">
    <!-- 1열: 연간 사용 내역 (대시보드) -->
    <div class="card">
      <div class="card-title">
        <span class="icon amber">📋</span> <span><span id="lvRecordYear">2026</span>년 사용 내역</span>
        <span class="badge emerald" id="lvRecordCount">0건</span>
      </div>
      <div id="lvRecordList">
        <p class="text-brand-text-muted text-center p-6">
          캘린더에서 날짜를 클릭하여 휴가를 등록하세요.
        </p>
      </div>
    </div>

    <!-- 2열: 2026년 휴가 현황 -->
    <div class="card">
      <div class="collapsible-header" onclick="toggleCollapsible('lvQuotaTableWrap')">
        <div class="flex items-center gap-2">
          <span class="toggle-icon">▼</span>
          <span class="card-title m-0 text-brand-title-large flex items-center gap-2"><span
              class="icon amber">🏖️</span> 2026년 휴가 현황</span>
        </div>
      </div>
      <div id="lvQuotaTableWrap" class="collapsible-body block">
        <div id="lvQuotaTable"></div>
        <div id="lvQuotaExtra"></div>
      </div>
    </div>
  </div>

  <!-- ── Desktop right-context panel (≥1280px only) ── -->
  <aside class="tab-desktop-context" aria-label="휴가 컨텍스트">
    <div class="ds-ctx-section">실시간 컨텍스트 · 휴가</div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">🌴 잔여 연차 <small id="leaveCtxPct">—</small></div>
      <div class="ds-ring-wrap">
        <div class="ds-ring">
          <svg width="52" height="52"><circle cx="26" cy="26" r="22" fill="none" stroke="#e5e7eb" stroke-width="6"></circle><circle id="leaveCtxRing" cx="26" cy="26" r="22" fill="none" stroke="#00B894" stroke-width="6" stroke-dasharray="0 138" stroke-linecap="round"></circle></svg>
          <div class="ds-ring-pct" id="leaveCtxRingLabel">—</div>
        </div>
        <div>
          <div style="font-size:11px;color:var(--text-muted);" id="leaveCtxRemain">— 일 사용 가능</div>
          <div style="font-size:10px;color:var(--text-muted);margin-top:1px;" id="leaveCtxUsed">— 일 사용 완료</div>
        </div>
      </div>
    </div>
    <div class="ds-ctx-card" style="border-color:var(--accent-amber); background:rgba(253,203,110,0.1);">
      <div class="ds-ctx-title">⏳ 소멸 임박</div>
      <div style="font-size:18px; font-weight:800; color:var(--accent-amber-text); font-family:'Space Grotesk','Inter',sans-serif;" id="leaveCtxExpiry">—</div>
      <div style="font-size:10px; color:var(--text-muted);">2026.12.31 까지 사용</div>
    </div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">📅 다가오는 휴가</div>
      <div id="leaveCtxUpcoming" style="font-size:11px; color:var(--text-secondary);">예정된 휴가 없음</div>
    </div>
    <div class="ds-ctx-card">
      <div class="ds-ctx-title">📊 6개월 사용 추이</div>
      <div class="ds-mini-bar" id="leaveCtxTrend"></div>
    </div>
  </aside>
</div>
