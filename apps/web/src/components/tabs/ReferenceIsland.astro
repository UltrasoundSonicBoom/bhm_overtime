---
// Phase 6 Task 5-5: ReferenceIsland.astro
// 기존 apps/web/public/tabs/tab-reference.html 컨텐츠를 Astro component 으로 inline.
// tab-loader.js fetch lazy-load 대신 빌드 시 inline → 콘솔 에러 0 + race 제거.
// 진입 hook: app.js 의 reference tab → regulation.js 동적 import → window.initRegulationFragment() 호출.
// HTML 본문은 tab-reference.html 에서 1:1 복사. 수정 금지.
// (Phase 5-followup-3 fix — iframe 제거, regulation main 컨텐츠 inline 패턴 보존)
// Phase 7-5: inline style → Tailwind utility. PDF 바텀시트 / chapter nav 시각 보존.
---
<div class="tab-content" id="tab-reference">
  <nav class="reg-bookmark-tabs" id="regSubTabs">
    <button class="reg-bookmark-tab active" data-subtab="browse">📋 규정·검색</button>
    <button class="reg-bookmark-tab" data-subtab="full">📜 전체 규정</button>
  </nav>

  <div class="sub-content active" id="subtab-browse">
    <!-- 검색 -->
    <div class="card px-4 py-3 mb-2">
      <input type="text" id="browseSearch" class="reg-search-input w-full"
        placeholder="규정 검색... (예: 연차, 야간수당, 경조비)">
    </div>

    <!-- 안내: 원문 번호 유지 정책 -->
    <div class="reg-info-banner">
      📘 <b>2026 단체협약 원문</b> 기준.
      <span style="opacity:0.8;">일부 조항 번호(예: 제13~17조, 제19~31조)는 단체협약 갱신 과정에서 <b>삭제·통합된 번호</b>이며 현행 협약에 존재하지 않습니다.</span>
    </div>

    <!-- 📖 목차 (장 가로 스크롤 탭 + 좌우 화살표) -->
    <div class="reg-section-label">📖 목차</div>
    <div class="reg-chapter-nav-wrap">
      <button type="button" class="reg-chapter-arrow left" data-action="scrollChapterTabs" data-scroll-direction="-1" aria-label="이전 장">◀</button>
      <div class="reg-chapter-tabs" id="browseChapterTabs"></div>
      <button type="button" class="reg-chapter-arrow right" data-action="scrollChapterTabs" data-scroll-direction="1" aria-label="다음 장">▶</button>
    </div>

    <!-- ⭐ 즐겨찾기 (가로 스크롤 칩) -->
    <div class="reg-section-label">⭐ 즐겨찾기</div>
    <div class="reg-fav-chips" id="browseFavChips"></div>

    <!-- 조항 리스트 (JSON 로드 전 즉시 보이는 placeholder — initBrowse 가 채움) -->
    <div id="browseArticles" class="mt-3">
      <div id="browseLoading" class="px-4 py-8 text-center text-brand-text-muted">
        <div class="text-2xl mb-2">📚</div>
        <div>규정을 불러오는 중...</div>
      </div>
    </div>

    <section id="fullRegulationPanel" class="reg-full-panel" aria-label="전체 규정 원문" hidden>
      <div class="reg-full-panel-header">
        <h2 class="reg-full-panel-title">전체 규정 원문</h2>
      </div>
      <div id="fullRegulationContent" class="reg-full-content"></div>
    </section>
  </div>

  <!-- ═══════════ 📜 전체 규정 sub-tab ═══════════ -->
  <div class="sub-content" id="subtab-full">
    <div class="card px-4 py-3 mb-2">
      <input type="text" id="fullRegSearch" class="reg-search-input w-full"
        placeholder="전체 규정 본문 검색... (예: 장기재직, 자기계발, 임신검진)">
    </div>
    <div class="reg-info-banner">
      📜 <b>2026 단체협약 전문 (3,155 lines)</b> — 검색·전체규정 모두 본 전문 기준.
      <span style="opacity:0.8;">조항을 클릭하면 검색 탭에서 인용·계산이 가능합니다.</span>
    </div>
    <div id="fullRegulationDoc" class="reg-full-doc">
      <div class="px-4 py-8 text-center text-brand-text-muted">
        <div class="text-2xl mb-2">📚</div>
        <div>전체 규정을 불러오는 중...</div>
      </div>
    </div>
  </div>

  <style is:global>
    /* 📜 전체 규정 마크다운 렌더 (Plan dazzling-booping-kettle redesign) */
    .reg-full-doc {
      padding: 12px 16px 80px;
      max-width: 760px;
      margin: 0 auto;
      line-height: 1.8;
      color: var(--text-primary, #1a1a1a);
    }
    .reg-full-doc h1 { font-size: 22px; font-weight: 800; margin: 22px 0 14px; padding-bottom: 8px; border-bottom: 2px solid var(--accent-indigo, #6366f1); }
    .reg-full-doc h2 { font-size: 19px; font-weight: 800; margin: 28px 0 12px; padding: 8px 12px; background: var(--bg-soft, rgba(99,102,241,0.08)); border-left: 4px solid var(--accent-indigo, #6366f1); border-radius: 4px; }
    .reg-full-doc h3 { font-size: 16px; font-weight: 700; margin: 22px 0 8px; color: var(--accent-indigo, #6366f1); scroll-margin-top: 80px; }
    .reg-full-doc h3.reg-art-target { animation: regArtFlash 1.6s ease-out; }
    @keyframes regArtFlash {
      0% { background: rgba(245, 158, 11, 0.45); }
      100% { background: transparent; }
    }
    .reg-full-doc p { margin: 6px 0; font-size: 14px; }
    .reg-full-doc ol, .reg-full-doc ul { margin: 6px 0 12px 22px; }
    .reg-full-doc li { font-size: 14px; line-height: 1.75; margin: 3px 0; }
    .reg-full-doc strong { color: var(--text-primary, #1a1a1a); font-weight: 700; }
    .reg-full-doc em { color: var(--text-secondary, #555); font-style: italic; }
    .reg-full-doc code { background: var(--bg-soft, rgba(0,0,0,0.05)); padding: 1px 6px; border-radius: 4px; font-size: 12px; color: var(--accent-rose, #f43f5e); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
    .reg-full-doc blockquote { border-left: 3px solid var(--text-muted, #9ca3af); padding: 4px 12px; color: var(--text-secondary, #555); background: var(--bg-soft, rgba(0,0,0,0.02)); margin: 10px 0; border-radius: 0 6px 6px 0; font-size: 13px; }
    .reg-full-doc table { border-collapse: collapse; width: 100%; margin: 12px 0; font-size: 13px; }
    .reg-full-doc th, .reg-full-doc td { border: 1px solid var(--border-default, #e5e7eb); padding: 6px 10px; text-align: left; vertical-align: top; }
    .reg-full-doc th { background: var(--bg-soft, rgba(99,102,241,0.06)); font-weight: 700; }
    .reg-full-doc hr { border: none; border-top: 1px dashed var(--border-default, #e5e7eb); margin: 18px 0; }
    .reg-full-doc .reg-amend { font-size: 11px; color: var(--accent-indigo, #6366f1); background: rgba(99,102,241,0.06); padding: 1px 6px; border-radius: 4px; margin-left: 6px; }
    .reg-full-doc mark { background: rgba(245, 158, 11, 0.35); padding: 0 2px; border-radius: 2px; }
  </style>

  <!-- ═══════════ PDF 바텀시트 ═══════════ -->
  <div class="pdf-sheet-overlay" id="pdfOverlay">
    <div class="pdf-sheet" id="pdfSheet">
      <div class="pdf-sheet-handle"></div>
      <div class="pdf-sheet-header">
        <span class="pdf-sheet-title" id="pdfSheetTitle">PDF 원문</span>
        <button class="pdf-sheet-close" id="pdfClose" title="닫기">✕</button>
      </div>
      <div class="pdf-sheet-controls">
        <button class="btn btn-outline" data-action="pdfPrevPage">◀</button>
        <span id="pdfPageInfo" class="pdf-page-info">- / -</span>
        <button class="btn btn-outline" data-action="pdfNextPage">▶</button>
        <span class="w-px h-5 bg-brand-border-glass"></span>
        <button class="btn btn-outline" data-action="pdfZoom" data-zoom-delta="-0.25">−</button>
        <span id="pdfZoomInfo" class="pdf-page-info">100%</span>
        <button class="btn btn-outline" data-action="pdfZoom" data-zoom-delta="0.25">+</button>
      </div>
      <div class="pdf-sheet-body" id="pdfSheetBody">
        <canvas id="pdfCanvas"></canvas>
      </div>
    </div>
  </div>
</div>
