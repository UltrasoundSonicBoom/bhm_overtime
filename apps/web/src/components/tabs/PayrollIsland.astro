---
// Phase 6 Task 5-3: PayrollIsland.astro
// 기존 apps/web/public/tabs/tab-payroll.html 컨텐츠를 Astro component 으로 inline.
// tab-loader.js 의 fetch lazy-load 대신 빌드 시 inline → 콘솔 에러 0 + race 제거.
// renderPayPayslip / renderPayHistory 등 init JS 는 payroll-views.js / app.js 에서 그대로 호출.
// HTML 본문은 tab-payroll.html 에서 1:1 복사. 수정 금지.
// Phase 5-followup-2 fix (label-for 패턴 — 파일 선택기 자동 트리거 버그 방지) 보존.
---
<div class="tab-content" id="tab-payroll">
  <!-- 책갈피 서브탭 -->
  <nav class="pay-bookmark-tabs" id="payrollSubTabs">
    <button class="pay-bookmark-tab active" data-subtab="pay-payslip">급여명세서 관리</button>
    <button class="pay-bookmark-tab" data-subtab="pay-calc">이번 달 예상액</button>
    <button class="pay-bookmark-tab" data-subtab="pay-qa">수당 계산기</button>
    <button class="pay-bookmark-tab" data-subtab="pay-retirement">퇴직금</button>
  </nav>
  <div class="pay-tab-accent" id="payTabAccent"></div>

  <!-- ── 서브탭 1: 급여명세서 관리 (시각적 뷰어 + 업로드 + 아카이브) ── -->
  <div class="sub-content active" id="sub-pay-payslip">
    <!-- 월 슬라이더 -->
    <div class="pay-month-slider" id="payMonthSlider"></div>
    <!-- 업로드 버튼 (슬라이더 바로 아래, 우측 정렬) -->
    <div id="payPayslipHeader" class="flex justify-end p-0 -mt-5 mb-5"></div>
    <!-- 시각적 명세서 뷰어 -->
    <div id="payPayslipVisual"></div>
    <!-- 아카이브 목록 -->
    <div id="payArchiveList"></div>
  </div>

  <!-- ── 서브탭 3: 급여 예상 ── -->
  <div class="sub-content" id="sub-pay-calc">

    <!-- ① 히어로: 월 슬라이더 + 실수령액 -->
    <div id="payEstHero"></div>

    <!-- ② 상세 명세서 카드 (지급/공제/시간외/연간요약) -->
    <div id="payEstTimeline"></div>

    <!-- ③ 상세 시뮬레이션 (숨김 — 급여예상 카드뷰로 대체) -->
    <div style="display:none;">
      <div class="collapsible-header mt-3" onclick="toggleCollapsible('payEstDetailForm')">
        <span class="flex items-center gap-2"><span class="toggle-icon">▸</span> 상세 시뮬레이션 설정</span>
      </div>
      <div class="collapsible-body" id="payEstDetailForm" style="display:none;">
        <div class="card border-2 border-brand-accent-indigo mt-2">
          <div class="card-title"><span class="icon text-brand-accent-indigo">🧾</span> 전체 급여 시뮬레이션</div>
          <p class="text-brand-body-normal text-brand-text-muted mb-3">📌 내 정보가 저장되어 있으면 자동 반영됩니다. 월별 변동사항만 입력하세요.</p>

          <div id="psProfileBanner" class="warning-box" style="display:none;"></div>

          <p class="text-brand-body-normal text-brand-text-primary mt-2 mb-1 font-semibold">▸ 시뮬레이션 월</p>
          <div class="form-row">
            <div class="form-group">
              <label>연도</label>
              <select id="psSimYear" onchange="autoFillMonth()">
                <option value="2025">2025년</option>
                <option value="2026" selected>2026년</option>
                <option value="2027">2027년</option>
                <option value="2028">2028년</option>
              </select>
            </div>
            <div class="form-group">
              <label>월</label>
              <select id="psSimMonth" onchange="autoFillMonth()">
                <option value="1">1월</option>
                <option value="2">2월</option>
                <option value="3" selected>3월</option>
                <option value="4">4월</option>
                <option value="5">5월</option>
                <option value="6">6월</option>
                <option value="7">7월</option>
                <option value="8">8월</option>
                <option value="9">9월</option>
                <option value="10">10월</option>
                <option value="11">11월</option>
                <option value="12">12월</option>
              </select>
            </div>
          </div>
          <div id="psHolidayInfo" class="text-brand-body-normal text-brand-text-muted mb-3"></div>

          <p class="text-brand-body-normal text-brand-text-primary mt-2 mb-1 font-semibold">▸ 이번달 변동사항</p>
          <div class="form-row">
            <div class="form-group">
              <label>근무일수</label>
              <input type="number" id="psWorkDays" value="22" min="0" max="31">
            </div>
            <div class="form-group">
              <label>야간근무가산 (횟수)</label>
              <input type="number" id="psNightShiftCount" value="0" min="0" max="31">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>연장근무 (시간)</label>
              <input type="number" id="psOvertime" value="0" min="0" step="0.25">
            </div>
            <div class="form-group">
              <label>야간근무 (시간)</label>
              <input type="number" id="psNight" value="0" min="0" step="0.25">
            </div>
          </div>
          <div class="form-group">
            <label>휴일근무 (시간)</label>
            <input type="number" id="psHoliday" value="0" min="0" step="0.25">
          </div>

          <!-- 캘린더 (접이식 참조용) -->
          <div class="collapsible-header" onclick="toggleCollapsible('psMiniCalContainer')">
            <span class="flex items-center gap-2"><span class="toggle-icon">▸</span> 달력 보기</span>
          </div>
          <div class="collapsible-body" id="psMiniCalContainer" style="display:none;">
            <div id="psMiniCalendar" class="mb-2"></div>
          </div>

          <div class="toggle-group">
            <input type="checkbox" id="psHolidayMonth">
            <label for="psHolidayMonth">명절지원비 해당월 (설·추석·5월·7월)</label>
          </div>

          <!-- 내 정보 없는 경우 직접 입력 영역 -->
          <div id="psManualSection">
            <div class="collapsible-header" onclick="toggleCollapsible('psManualFields')">
              <span class="flex items-center gap-2"><span class="toggle-icon">▸</span> 내 정보 미저장 시 직접 입력</span>
            </div>
            <div class="collapsible-body" id="psManualFields" style="display:none;">
              <div class="form-group">
                <label>직종</label>
                <select id="psJobType" onchange="updatePayrollGrades()">
                </select>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>직급</label>
                  <select id="psGrade"></select>
                </div>
                <div class="form-group">
                  <label>호봉</label>
                  <select id="psYear">
                    <option value="1">1년차</option>
                    <option value="2">2년차</option>
                    <option value="3">3년차</option>
                    <option value="4">4년차</option>
                    <option value="5">5년차</option>
                    <option value="6">6년차</option>
                    <option value="7">7년차</option>
                    <option value="8">8년차</option>
                  </select>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>근속연수</label>
                  <input type="number" id="psServiceYears" value="1" min="0" max="40">
                </div>
                <div class="form-group">
                  <label>조정급 (원/월)</label>
                  <input type="number" id="psAdjust" value="0" min="0">
                </div>
              </div>
              <div class="toggle-group">
                <input type="checkbox" id="psMilitary">
                <label for="psMilitary">군복무수당</label>
              </div>
              <div class="toggle-group">
                <input type="checkbox" id="psSeniority">
                <label for="psSeniority">근속가산기본급</label>
              </div>
              <div class="toggle-group">
                <input type="checkbox" id="psSpouse">
                <label for="psSpouse">배우자 (40,000원)</label>
              </div>
            </div>
          </div>

          <button class="btn btn-primary btn-full mt-3" onclick="calculatePayroll()">급여 시뮬레이션</button>

          <div id="payrollResult" class="mt-4">
            <p class="text-brand-text-muted">위에서 정보를 입력하고 [급여 시뮬레이션]을 눌러주세요.</p>
          </div>
        </div>
      </div>
    </div><!-- /상세 시뮬레이션 숨김 wrapper -->

    <!-- 급여 검증 (숨김, 명세서 업로드 후 활성화) -->
    <div id="verifyCard" class="card" style="display:none;">
      <div class="card-title"><span class="icon text-[color:var(--accent-emerald)]">✅</span> 앱 계산값 vs 명세서 비교</div>
      <div id="verifyResult"></div>
    </div>

  </div><!-- /sub-pay-calc -->

  <!-- ── 서브탭 4: 급여 계산 (수당 바로 계산) ── -->
  <div class="sub-content" id="sub-pay-qa">
    <div id="qaCardsContainer"></div>
  </div><!-- /sub-pay-qa -->

  <!-- ── 서브탭 5: 퇴직금 (재설계 2026-04-30) ── -->
  <!-- plan: reactive-sprouting-sprout.md · 디자인 시안: ~/.gstack/projects/.../retirement-tab-redesign-20260430/ -->
  <div class="sub-content" id="sub-pay-retirement">

    <!-- 3 서브탭 네비게이션 (4 → 3 통합) -->
    <nav class="ret-bookmark-tabs" id="retTabs">
      <button class="ret-bookmark-tab active" data-tab="sim">🧮 시뮬레이터</button>
      <button class="ret-bookmark-tab" data-tab="timeline">📅 타임라인</button>
      <button class="ret-bookmark-tab" data-tab="learn">📚 알아두기</button>
    </nav>
    <div class="ret-tab-accent sim" id="retTabAccent"></div>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Tab 1: 시뮬레이터 (Wizard 3-step) -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <div class="ret-panel active" id="ret-panel-sim">

      <!-- 🛡️ 평균임금 보호조항 hero 배너 -->
      <div class="ret-protect-banner">
        <span class="ico">🛡️</span>
        <span>핵심: <b>공로연수를 선택해도 퇴직금은 동일</b>. 평균임금은 공로연수 전 3개월 기준으로 보호됩니다 (제52조).</span>
      </div>

      <!-- Wizard 진행률 -->
      <div class="ret-wiz-progress" id="retWizProgress">
        <div class="ws cur" data-step="1"></div>
        <div class="ws" data-step="2"></div>
        <div class="ws" data-step="3"></div>
      </div>
      <div class="ret-wiz-step-label" id="retWizStepLabel">1 / 3 — 평균임금 입력</div>

      <!-- Step 1: 평균임금 + 환경 입력 -->
      <div class="ret-wiz-step active" data-step="1">
        <div id="retAutoLoadBanner"
          class="mb-3 py-3 px-3.5 text-brand-body-normal leading-relaxed rounded-lg bg-[#e0e7ff] border-[2.5px] border-solid border-[#4338ca] shadow-[3px_3px_0px_#1a1a1a]"
          style="display:none;">
          <div class="font-bold mb-1 text-[#1e1b4b]">⚡ 내 정보 자동 반영</div>
          <div id="retAutoLoadDetail" class="text-[#312e81]"></div>
        </div>

        <div class="ret-card">
          <div class="ret-card-title">📋 평균임금 입력</div>
          <div class="ret-form-row">
            <label class="ret-label">월 평균임금 (원) <span class="text-[11px] text-brand-text-muted font-normal ml-1" id="retWageSourceLabel"></span></label>
            <input class="ret-input" type="number" id="retAvgWage"
              placeholder="명세서 3개월이 있으면 자동, 없으면 수동 입력" min="0" step="10000">
            <div class="text-[11px] text-brand-text-muted leading-[1.7] mt-1">
              • 근로기준법 제2조 제1항 6호: 평균임금 = 퇴직 전 3개월 임금 / 역일수<br>
              • 근로기준법 제2조 제2항: 평균임금이 통상임금보다 낮으면 → 통상임금 적용 (보호 조항)
            </div>
          </div>
        </div>

        <div class="ret-card">
          <div class="ret-card-title">📅 입사일·생년월일</div>
          <div class="ret-form-row">
            <label class="ret-label">생년월일 <span class="text-[11px] text-brand-text-muted font-normal">(D-day·정년 계산용)</span></label>
            <input class="ret-input" type="date" id="retBirthDate"
              oninput="retUpdateQuickDates(); syncBirthDateToProfile(this.value)">
          </div>
          <div class="ret-dday-grid mb-2.5" id="retDdayGrid" style="display:none;">
            <div class="ret-dday-card">
              <div class="ret-dday-label">정년 1년 전까지</div>
              <div class="ret-dday-val" id="retDdayPeak">—</div>
            </div>
            <div class="ret-dday-card">
              <div class="ret-dday-label">정년퇴직 예정일</div>
              <div class="ret-dday-val" id="retDdayRetire">—</div>
            </div>
          </div>
          <div class="ret-form-row">
            <label class="ret-label">입사일</label>
            <input class="ret-input" type="date" id="retHireDate" oninput="retUpdateQuickDates()">
          </div>
        </div>
      </div>

      <!-- Step 2: 공로연수 선택 (hero) + 퇴직(예정)일 빠른선택 -->
      <div class="ret-wiz-step" data-step="2">
        <div class="ret-card">
          <div class="ret-card-title">🎓 공로연수, 어떻게 할까요?</div>
          <div class="text-[12px] text-brand-text-secondary leading-relaxed mb-2">정년 직전 1년 보수 옵션. 노조 합의 2019.11 / 2022.12 기준.</div>
          <div id="retPeakExclusionNote" class="ret-guide-note mb-2" style="display:none;">⚠️ 입사일로부터 5년 이내 정년에 도달하는 경우 공로연수 선택 적용 대상에서 제외됩니다.</div>
          <div class="ret-peak-opts" id="retPeakOptSection">
            <label class="ret-peak-opt selected" id="retPeakOpt_none" onclick="retSelectPeakOpt(this)">
              <input type="radio" name="retPeakOpt" value="none" checked>
              <div class="ret-peak-opt-body">
                <div class="ret-peak-opt-title">해당없음 — 법정 정년(만 60세)에 퇴직</div>
                <div class="ret-peak-opt-desc">정년퇴직일 기준으로 입력한 월 평균임금 그대로 퇴직금 산정</div>
              </div>
            </label>
            <label class="ret-peak-opt" id="retPeakOpt_A" onclick="retSelectPeakOpt(this)">
              <input type="radio" name="retPeakOpt" value="A">
              <div class="ret-peak-opt-body">
                <div class="ret-peak-opt-title">옵션 A — 공로연수 1년 선택 (기준 보수 × 60%)</div>
                <div class="ret-peak-opt-desc">실제 근무지 출근 없이 규정 지급액 수령. 퇴직금은 공로연수 전 3개월 평균임금 기준 보호 → <b>퇴직금 동일</b></div>
              </div>
            </label>
            <label class="ret-peak-opt" id="retPeakOpt_B" onclick="retSelectPeakOpt(this)">
              <input type="radio" name="retPeakOpt" value="B">
              <div class="ret-peak-opt-body">
                <div class="ret-peak-opt-title">옵션 B — 공로연수 미선택·계속근무 (직전년도 보수 × 100%)</div>
                <div class="ret-peak-opt-desc">1년 계속 근무. 호봉상승·임금인상분·승진·승격은 제외</div>
              </div>
            </label>
          </div>
          <label class="ret-checkbox-row" id="retSeveranceCheckRow" style="display:none;">
            <input type="checkbox" id="retSeveranceCheck" checked>
            <span class="ret-checkbox-label">퇴직수당 포함 계산 (2015.6.30 이전 입사자)</span>
          </label>
        </div>

        <div class="ret-card">
          <div class="ret-card-title">📅 퇴직(예정)일</div>
          <div class="ret-form-row">
            <div class="ret-quick-dates" id="retQuickDates" style="display:none;">
              <button class="ret-quick-btn" id="retBtnNow" onclick="retSetRetireDate('now')">지금 바로</button>
              <button class="ret-quick-btn" id="retBtnPeakDate" onclick="retSetRetireDate('peak')">정년 1년 전</button>
              <button class="ret-quick-btn" id="retBtnPeakEndDate" onclick="retSetRetireDate('peakEnd')">정년퇴직 예정일</button>
            </div>
            <input class="ret-input" type="date" id="retRetireDate">
          </div>
        </div>

        <div class="ret-protect-banner">
          <span class="ico">🛡️</span>
          <span>어느 옵션을 골라도 <b>퇴직금 산정 평균임금은 동일</b>. 보수 차이는 <b>재직 중 1년치 급여</b> 차이일 뿐입니다.</span>
        </div>
      </div>

      <!-- Step 3: 결과 -->
      <div class="ret-wiz-step" data-step="3">
        <div class="ret-warning" id="retPre2001Warning">
          ⚠️ 2001.8.31 이전 근속분이 포함되어 있습니다. 해당 부분의 퇴직금은 인사과에 직접 문의해 주세요.
        </div>
        <button class="ret-calc-btn" onclick="calcRetirementEmbedded()">퇴직금 계산하기</button>
        <div class="ret-result" id="retCalcResult" style="display:none;">
          <div class="ret-result-label" id="retCalcResultLabel">예상 퇴직금</div>
          <div class="ret-result-amount" id="retCalcResultTotal">0원</div>
          <div class="ret-result-breakdown" id="retCalcResultBreakdown"></div>
        </div>
        <div id="retAiSuggestion" style="display:none;"></div>
        <p class="ret-notice">※ 실제 금액은 개인별 수당·세금 공제에 따라 달라집니다. 최종 확인은 인사과에 문의하세요.</p>

        <div class="ret-protect-banner">
          <span class="ico">🛡️</span>
          <span><b>퇴직금은 두 시나리오 모두 동일</b>. 평균임금은 공로연수 전 기준 보호 → <b>📅 타임라인 탭</b>에서 직접 비교 가능.</span>
        </div>

        <div class="ret-card ret-rate-card mt-1" id="retRateCard">
          <div class="ret-card-title ret-rate-toggle cursor-pointer flex justify-between items-center select-none" onclick="retToggleRateCard()">
            <span>📊 근속연수별 퇴직금 지급률</span>
            <span class="ret-rate-chevron text-xs text-brand-text-muted transition-transform duration-200" id="retRateChevron">▲</span>
          </div>
          <div id="retRateCardBody">
            <div class="overflow-x-auto">
              <table class="w-full border-collapse text-brand-body-normal">
                <thead>
                  <tr class="border-b-2 border-b-[#1a1a1a] bg-[rgba(129,140,248,0.12)]">
                    <th class="p-2 text-center">근속</th>
                    <th class="p-2 text-center">지급률(월)</th>
                    <th class="p-2 text-center">근속</th>
                    <th class="p-2 text-center">지급률(월)</th>
                  </tr>
                </thead>
                <tbody id="retRateTableBody"></tbody>
              </table>
            </div>
            <div class="text-[11px] text-brand-text-muted mt-2.5 leading-[1.8]">
              <div>📌 <strong>위 표는 2001.8.31 이전 입사자에게 적용되는 누진배수</strong>입니다.</div>
