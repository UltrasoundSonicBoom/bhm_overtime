---
// Phase 6 Task 4-1: BaseLayout
// 9 entry HTML 의 공통 head/header/footer 구조를 단일 layout 으로 추출.
// Plan: docs/superpowers/plans/2026-04-27-phase6-astro-turbo-ts.md (Step 4.1)
// Phase 6 Task 4-2: globals.css 는 Astro import 로 hash-bundle, dark/regulation 은 public/styles/* URL 로 dynamic load.
import '../styles/globals.css';

interface Props {
  title: string;
  description?: string;
  showFooterNav?: boolean;
  extraCss?: string[];
}

const {
  title,
  description = 'SNUH Mate',
  showFooterNav = true,
  extraCss = [],
} = Astro.props;
---
<!DOCTYPE html>
<html lang="ko" data-theme="neo">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <!-- Firebase CDN 사전 연결 — 로그인 버튼 클릭 전 DNS+TCP 준비 -->
  <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.gstatic.com" />
  <link rel="preconnect" href="https://identitytoolkit.googleapis.com" crossorigin />
  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/snuhmaterect.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/snuhmaterect.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/snuhmaterect.png" />
  {extraCss.map((href) => <link rel="stylesheet" href={href} />)}
  <script is:inline>
    // dark 조건부 로드 (Plan 1 산출 그대로)
    (function(){try{var t=localStorage.getItem("theme");if(t==="dark"||t==="linear"){document.documentElement.setAttribute("data-theme","dark");var d=document.createElement("link");d.rel="stylesheet";d.href="/styles/dark.css";document.head.appendChild(d);if(t==="linear")localStorage.setItem("theme","dark")}}catch(e){}})();
  </script>
</head>
<body class="min-h-screen antialiased">
  <header id="sharedHeader" class="block w-full"></header>
  <slot />
  {showFooterNav && <nav id="sharedFooter" class="block w-full"></nav>}
  <script type="module">
    // Firebase SDK 백그라운드 초기화 — 로그인 버튼 클릭 전 SDK 준비
    // singleton(_initPromise)이므로 실제 로그인 시점엔 이미 로드됨
    import('/src/client/config.js').then(({ firebaseConfig }) => {
      if (!firebaseConfig?.apiKey) return;
      import('/src/firebase/firebase-init.js').then(({ initFirebase }) => {
        initFirebase(firebaseConfig).catch(() => {});
      }).catch(() => {});
    }).catch(() => {});
  </script>
</body>
</html>
