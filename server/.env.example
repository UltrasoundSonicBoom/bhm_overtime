# Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:[PASSWORD]@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Neon Auth (Managed) — Neon Console > Auth 탭에서 확인
NEON_AUTH_BASE_URL=https://ep-xxx.us-east-2.aws.neon.tech/auth

# OpenAI API (임베딩 + LLM)
OPENAI_API_KEY=sk-...

# Google OAuth (Neon Auth Google provider 설정에 사용)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
