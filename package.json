{
  "name": "snuhmate",
  "version": "1.0.0",
  "description": "SNUH Mate — 서울대병원 직원용 급여, 시간외, 휴가, 근무표, 규정, 팀 운영 도구",
  "main": "app.js",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:smoke",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "playwright test",
    "check:regulation": "node scripts/check-regulation-link.cjs",
    "check:paytable": "node scripts/check-paytable.cjs",
    "verify": "pnpm security:ops",
    "verify:data": "pnpm check:regulation && pnpm check:paytable",
    "security:rules": "firebase emulators:exec --only firestore --project=snuhmate-test \"pnpm vitest run tests/integration/firebase/security-rules.test.js\"",
    "verify:security": "pnpm vitest run tests/integration/firebase tests/integration/security-ops-contract.test.js && pnpm security:rules",
    "security:ops": "pnpm check && pnpm build && pnpm verify:data && pnpm test:unit && pnpm test:integration && pnpm verify:security && pnpm test:smoke",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "pnpm --filter @snuhmate/web dev",
    "build": "pnpm --filter @snuhmate/web build",
    "preview": "pnpm --filter @snuhmate/web preview",
    "check": "pnpm --filter @snuhmate/web check",
    "web:dev": "pnpm --filter @snuhmate/web dev",
    "web:build": "pnpm --filter @snuhmate/web build",
    "web:check": "pnpm --filter @snuhmate/web check",
    "backend:dev": "cd backend && poetry run uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload",
    "backend:test": "cd backend && poetry run pytest",
    "turbo:build": "turbo run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UltrasoundSonicBoom/bhm_overtime.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/UltrasoundSonicBoom/bhm_overtime/issues"
  },
  "homepage": "https://snuhmate.com",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@snuhmate/calculators": "workspace:*",
    "@snuhmate/data": "workspace:*",
    "@snuhmate/profile": "workspace:*",
    "@snuhmate/regulation-constants": "workspace:*",
    "@snuhmate/scheduling": "workspace:*",
    "@snuhmate/shared-utils": "workspace:*",
    "eslint": "^10.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "firebase-tools": "^15.15.0",
    "globals": "^17.5.0",
    "ical.js": "^2.2.1",
    "jsdom": "^29.1.0",
    "papaparse": "^5.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
