{
  "name": "snuhmate",
  "version": "1.0.0",
  "description": "SNUH Mate — 서울대병원 노조 직원용 급여/시간외/휴가/근무이력/규정 PWA",
  "main": "app.js",
  "private": true,
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:integration && npm run test:smoke",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "playwright test",
    "check:regulation": "node scripts/check-regulation-link.cjs",
    "check:paytable": "node scripts/check-paytable.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "web:dev": "pnpm --filter @snuhmate/web dev",
    "web:build": "pnpm --filter @snuhmate/web build",
    "turbo:build": "turbo run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UltrasoundSonicBoom/bhm_overtime.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/UltrasoundSonicBoom/bhm_overtime/issues"
  },
  "homepage": "https://snuhmate.com",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@snuhmate/calculators": "workspace:*",
    "@snuhmate/data": "workspace:*",
    "@snuhmate/profile": "workspace:*",
    "@snuhmate/regulation-constants": "workspace:*",
    "@snuhmate/shared-utils": "workspace:*",
    "eslint": "^10.2.1",
    "firebase-tools": "^15.15.0",
    "globals": "^17.5.0",
    "ical.js": "^2.2.1",
    "jsdom": "^29.1.0",
    "papaparse": "^5.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
